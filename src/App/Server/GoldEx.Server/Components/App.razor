<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#daa520" />
    <base href="/" />

    <link href="@Assets["manifest.webmanifest"]" rel="manifest" />

    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180x180.png" />

    <link rel="stylesheet" href="@Assets["css/lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["GoldEx.Server.styles.css"]" />
    <link rel="stylesheet" href="@Assets["css/app.css"]" />

    <ImportMap />

    <link href=@Assets["_content/MudBlazor/MudBlazor.min.css"] rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.ico" />
    <HeadOutlet @rendermode="RenderModeForPage" />
</head>

<body>
    @if (Env.IsDevelopment())
    {
        <Routes @rendermode="RenderModeForPage" />
    }
    else
    {
        @if (_license is not null)
        {
            @if (_license.Plan is Shared.Enums.LicensePlan.Unregistered && IsLoggedIn)
            {
                <UnregisteredRoute @rendermode="RenderModeForPage" />
            }
            else
            {
                <Routes @rendermode="RenderModeForPage" />
            }
        }
    }

    <script src="app.js"></script>
    <script src=@Assets["_framework/blazor.web.js"] autostart="false"></script>
    <script>
        Blazor.start({
            webAssembly: {}
        });
    </script>
    <script src="@Assets["_content/MudBlazor/MudBlazor.min.js"]"></script>
    <script src=@Assets["sw-events.js"]></script>
    <script>swEvents.startListening();</script>
</body>

</html>