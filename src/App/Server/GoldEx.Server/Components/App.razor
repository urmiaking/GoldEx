<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />

    <link href="@Assets["manifest.webmanifest"]" rel="manifest" />
    <link rel="apple-touch-icon" sizes="512x512" href="@Assets["icon-512.png"]" />
    <link rel="apple-touch-icon" sizes="192x192" href="@Assets["icon-192.png"]" />

    <link rel="stylesheet" href="@Assets["css/lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["GoldEx.Server.styles.css"]" />
    <link rel="stylesheet" href="@Assets["css/app.css"]" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&display=swap" rel="stylesheet">

    <ImportMap />

    <!-- Add MudBlazor -->
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href=@Assets["_content/MudBlazor/MudBlazor.min.css"] rel="stylesheet" />
    <link id="mudex-styles" href=@Assets["_content/MudBlazor.Extensions/mudBlazorExtensions.min.css"] rel="stylesheet">
    <!-- -->

    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="RenderModeForPage" />
</head>

<body>
    <!-- Loading indicator -->
    @if (RenderModeForPage is InteractiveWebAssemblyRenderMode)
    {
        <div id="loading-indicator" class="loading-container">
            <div class="loading-card">
                <img src="icon-512.png" alt="GoldEx Logo" class="loading-logo" />
                <h1 class="loading-title">
                    سامانه جامع حسابداری طلا و جواهر 
                    <span class="brand-text">GoldEx</span>
                </h1>
                <div class="spinner-border loading-spinner" role="status">
                    <span class="visually-hidden">در حال بارگذاری...</span>
                </div>
                <p class="loading-text"></p>
            </div>
        </div>
    }


    <Routes @rendermode="RenderModeForPage" />
    <script src="app.js"></script>
    <script src=@Assets["_framework/blazor.web.js"] autostart="false"></script>
    <script>
        Blazor.start({
            webAssembly: {}
        });
    </script>
    
    <script src=@Assets["_content/MudBlazor/MudBlazor.min.js"]></script>

    <script src=@Assets["sw-events.js"]></script>
    <script>swEvents.startListening();</script>
</body>

</html>
