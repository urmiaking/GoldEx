@using GoldEx.Shared.Enums
@attribute [Route(ClientRoutes.Accounts.Login)]

@inject SignInManager<AppUser> SignInManager
@inject ILogger<Login> Logger
@inject IdentityRedirectManager RedirectManager
@inject IHttpClientFactory HttpClientFactory
@inject IConfiguration Config
@layout EmptyBoxLayout

<PageTitle>ورود</PageTitle>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<MudStack AlignItems="AlignItems.Center">
    <MudItem>
        <span class="brand-text" dir="ltr">GoldEx</span>
    </MudItem>
</MudStack>

<EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
    <MudGrid>
        <MudItem xs="12">
            <MudStaticTextField For="@(() => Input.Username)" @bind-Value="Input.Username"
                                Label="نام کاربری" 
                                UserAttributes="@(new Dictionary<string, object?> { { "autocomplete", "username" }, { "aria-required", "true" } })" />
        </MudItem>
        <MudItem xs="12">
            <MudStaticTextField For="@(() => Input.Password)" @bind-Value="Input.Password"
                                Label="رمز عبور" InputType="InputType.Password"
                                UserAttributes="@(new Dictionary<string, object?> { { "autocomplete", "password" }, { "aria-required", "true" } })" />
        </MudItem>
        <MudItem xs="12" Class="m-0 p-0">
            <MudStaticCheckBox For="@(() => Input.RememberMe)" @bind-Value="Input.RememberMe">مرا بخاطر بسپار</MudStaticCheckBox>
        </MudItem>

        @if (_showCaptcha)
        {
            <div class="cf-turnstile d-flex justify-center w-100" data-theme="light" data-sitekey="@_siteKey"></div>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudItem xs="12" Class="mb-0">
                <StatusMessage Message="@_errorMessage" Severity="Severity.Error" />
            </MudItem>
        }

        <MudItem xs="12" Class="mt-0">
            <div class="d-flex align-center gap-2 w-100">
                <MudStaticButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                 FormAction="FormAction.Submit" StartIcon="@Icons.Material.Filled.Login">
                    ورود به سامانه
                </MudStaticButton>

                <div id="passkey-login-section" style="display: none">
                    <PasskeySubmit Name="Input.Passkey"
                                   Auto="true"
                                   Username="Input.Username"/>
                </div>
            </div>
        </MudItem>
    </MudGrid>
</EditForm>

<MudGrid Class="mt-1">
    <MudItem xs="6">
        <MudButton StartIcon="@Icons.Material.Filled.Phone" Variant="Variant.Filled" FullWidth="true"
                   Color="Color.Primary" Href="@ClientRoutes.Accounts.LoginWithPhoneNumber">ارسال پیامک</MudButton>
    </MudItem>
    <MudItem xs="6">
        <ExternalLoginPicker ExternalLoginPickerSource="ExternalLoginSource.Login" />
    </MudItem>
</MudGrid>

<MudGrid>
    <MudItem xs="12" Class="text-center mt-3">
        <MudLink Href="@ClientRoutes.Accounts.ForgotPassword">رمز عبور خود را فراموش کرده اید؟</MudLink><br />
    </MudItem>
</MudGrid>

<script>
    function initPasskeyAutoOpen() {
        const containerId = 'passkey-login-section';
        const storageKey = 'device_registered_passkey';
        const container = document.getElementById(containerId);

        if (!container) return;

        const isRegistered = localStorage.getItem(storageKey) === 'true';

        if (isRegistered) {
            container.style.display = 'flex';
            customElements.whenDefined('passkey-submit').then(() => {
                const passkeyComponent = container.querySelector('passkey-submit');

                if (passkeyComponent && typeof passkeyComponent.obtainAndSubmitCredential === 'function') {
                    if (!passkeyComponent.hasAttribute('data-auto-triggered')) {
                        passkeyComponent.setAttribute('data-auto-triggered', 'true');
                        console.log("Auto-triggering passkey modal...");
                        passkeyComponent.obtainAndSubmitCredential(false);
                    }
                }
            });
        }
    }

    initPasskeyAutoOpen();

    if (typeof Blazor !== 'undefined') {
        Blazor.removeEventListener('enhancedload', initPasskeyAutoOpen);
        Blazor.addEventListener('enhancedload', initPasskeyAutoOpen);
    }
</script>
