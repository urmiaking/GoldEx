@using GoldEx.Shared.DTOs.Transactions
@inherits GoldExComponentBase

<MudTable T="GetTransactionResponse" RowsPerPage="14" Hover="true" @ref="_table" FixedHeader="true" GroupBy="@_groupDefinition" ContainerClass="@ContainerClass"
          Dense="true" ServerData="LoadTransactionsAsync" SelectOnRowClick="false" Breakpoint="Breakpoint.Sm" Elevation="0">
    <ToolBarContent>
        @if (!string.IsNullOrEmpty(TableTitle))
        {
            <MudText Typo="Typo.body1">@TableTitle</MudText>
        }
        else
        {
            <MudTextField T="string" Clearable="true" Immediate="true" ValueChanged="@(s => OnSearch(s))" DebounceInterval="500"
                          Placeholder="جستجو ..." Adornment="Adornment.Start" Variant="Variant.Outlined" Margin="Margin.Dense"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"></MudTextField>
            <MudSpacer />
            <MudHidden Breakpoint="Breakpoint.SmAndDown" Class="w-75">
                <MudDateRangePicker DateRange="@_filterDateRange"
                                    DateRangeChanged="OnDateRangeChanged"
                                    Margin="Margin.Dense"
                                    Variant="Variant.Outlined"
                                    Class="ml-3"
                                    MaxMonthColumns="1"
                                    DisplayMonths="1"
                                    Rounded="true"
                                    ShowToolbar="false"
                                    Style="max-width: 320px;"
                                    PlaceholderStart="از"
                                    PlaceholderEnd="تا"
                                    Elevation="24"
                                    RelativeWidth="DropdownWidth.Adaptive"
                                    Label="تاریخ تراکنش"
                                    Clearable="true" />
                                    
                @if (_priceUnits is not null && _priceUnits.Any())
                {
                    <MudButtonGroup Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Class="ml-3">
                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.AttachMoney">
                            @(_priceUnit == null ? "همه ارزها" : _priceUnit.Title)
                        </MudButton>
                        <MudMenu Size="Size.Small" Icon="@Icons.Material.Filled.ArrowDropDown" Style="align-self: auto;">
                            <MudMenuItem IconColor="Color.Primary" Icon="@Icons.Material.Filled.Menu"
                                         OnClick="() => SetPriceUnit(null)">همه ارزها</MudMenuItem>
                            @foreach (var priceUnit in _priceUnits)
                            {
                                <MudMenuItem IconColor="Color.Success" Icon="@Icons.Material.Filled.MonetizationOn"
                                             OnClick="() => SetPriceUnit(priceUnit)">@priceUnit.Title</MudMenuItem>
                            }
                        </MudMenu>
                    </MudButtonGroup>
                }
                
            </MudHidden>
        }
    </ToolBarContent>
    <ColGroup>
        <col />
        <col />
        <col />
        <col />
        <col />
    </ColGroup>
    <HeaderContent>
        <MudTh>تاریخ</MudTh>
        <MudTh>نوع تراکنش</MudTh>
        <MudTh>مبلغ</MudTh>
        <MudTh>شرح</MudTh>
        <MudTh>حساب تحت تاثیر</MudTh>
    </HeaderContent>
    <GroupHeaderTemplate>
        <MudTh colspan="5" Style="background-color: var(--mud-palette-table-striped);"></MudTh>
    </GroupHeaderTemplate>
    <RowTemplate>
        <MudTd DataLabel="تاریخ">
            <MudTooltip Text="@context.PostingDate.ToString("yyyy/MM/dd HH:mm:ss")" Arrow="true" Placement="Placement.Top">
                @context.PostingDate.ToString("yyyy/MM/dd")
            </MudTooltip>
        </MudTd>
        <MudTd DataLabel="نوع تراکنش">
            @if (context.TransactionType == TransactionType.Credit)
            {
                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.KeyboardArrowUp">
                    @context.TransactionType.GetDisplayName()
                </MudChip>
            }
            else
            {
                <MudChip T="string" Color="Color.Error" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.KeyboardArrowDown">
                    @context.TransactionType.GetDisplayName()
                </MudChip>
            }
        </MudTd>
        <MudTd DataLabel="مبلغ">@context.Amount.ToCurrencyFormat(context.PriceUnit)</MudTd>
        <MudTd DataLabel="شرح">@context.Description</MudTd>
        <MudTd DataLabel="حساب تحت تاثیر">@context.LedgerAccount</MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>هیچ تراکنشی یافت نشد</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>در حال بارگیری</MudText>
    </LoadingContent>
    <PagerContent>
        @{
            var totalItems = _table.GetFilteredItemsCount();
            var startItem = totalItems == 0 ? 0 : _table.CurrentPage * _table.RowsPerPage + 1;
            var endItem = Math.Min((_table.CurrentPage + 1) * _table.RowsPerPage, totalItems);
            var pageCount = (totalItems + _table.RowsPerPage - 1) / _table.RowsPerPage;
            var infoText = $"نمایش {startItem} تا {endItem} از {totalItems} ردیف";
        }

        <div class="d-flex flex-column flex-sm-row align-center justify-sm-space-between w-100 pa-4" style="gap: 1rem;">
            <div class="mud-table-pagination-caption">
                @infoText
            </div>
            <MudPagination SelectedChanged="PageChanged"
                           Selected="@(_table.CurrentPage + 1)"
                           Color="Color.Primary"
                           Count="@pageCount"
                           Class="justify-center"
                           BoundaryCount="1"
                           MiddleCount="3" />

            <div class="d-none d-sm-block mud-table-pagination-caption" style="visibility: hidden; pointer-events: none;">
                @infoText
            </div>
        </div>
    </PagerContent>
</MudTable>
<style>
    .mud-table-toolbar:empty {
        display: none;
    }
</style>