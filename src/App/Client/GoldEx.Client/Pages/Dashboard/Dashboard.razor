@attribute [Route(ClientRoutes.Dashboard.Index)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

@inherits GoldExComponentBase

<PageTitle>داشبورد</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="pr-0" Items="_breadcrumbs">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>

    <PriceList />
    <MudGrid>
        <MudItem xs="12" sm="6" md="3" Class="mt-6">
            <InventoryWeightChart />
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Class="mt-6">
            <HealthMonitor />
        </MudItem>
    </MudGrid>

</MudContainer>