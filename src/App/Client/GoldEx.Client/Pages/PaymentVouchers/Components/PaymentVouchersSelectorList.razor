@using GoldEx.Shared.DTOs.PaymentVouchers
@inherits GoldExComponentBase

<MudDialog>
    <DialogContent>
        <MudTable T="GetPaymentVoucherResponse" Hover="true" FixedHeader="true" Dense="true" Items="_paymentVouchers" Loading="IsBusy"
                  @bind-SelectedItems="_selectedItems" SelectOnRowClick="true" MultiSelection="true" Breakpoint="Breakpoint.Xs" Elevation="0">
            <HeaderContent>
                <MudTh>شماره سند</MudTh>
                <MudTh>ارزش کل</MudTh>
                <MudTh>شرح</MudTh>
                <MudTh>تاریخ پرداخت</MudTh>
                <MudTh>پرداخت از حساب</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ردیف">@context.VoucherNumber</MudTd>
                <MudTd DataLabel="ارزش کل">@context.Amount.ToCurrencyFormat(context.PriceUnit?.Title)</MudTd>
                <MudTd DataLabel="شرح">@context.Description</MudTd>
                <MudTd DataLabel="تاریخ پرداخت">@context.PaymentDate.ToShortDateString()</MudTd>
                <MudTd DataLabel="پرداخت از حساب">@context.SourceFinancialAccount.Title</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>هیچ سند پرداختی وجود ندارد</MudText>
            </NoRecordsContent>
            <LoadingContent>
                <MudText>در حال بارگیری</MudText>
            </LoadingContent>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Error"
                   OnClick="Close"
                   StartIcon="@Icons.Material.Filled.Close"
                   Variant="Variant.Filled">انصراف</MudButton>

        <MudButton Class="m-2"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="Submit"
                   Variant="Variant.Filled">
            <MudText>ذخیره</MudText>
        </MudButton>
    </DialogActions>
</MudDialog>