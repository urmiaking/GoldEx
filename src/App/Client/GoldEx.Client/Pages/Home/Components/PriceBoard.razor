@inherits GoldExComponentBase

@if (ShowTitle)
{
    <div class="d-flex justify-content-center">
        <MudText Typo="Typo.h5" GutterBottom="true" Class="mt-6">تابلوی قیمت ها</MudText>
    </div>
    <MudDivider />
}

@if (_items is null)
{
    <PriceBoardSkeleton Class="@Class" Elevation="@Elevation" ContainerClass="@ContainerClass" />
}
else
{
    <MudTable Hover="true" Dense="true" Breakpoint="Breakpoint.Xs" ContainerClass="@ContainerClass" FixedHeader="true" Elevation="@Elevation"
              Items="@_items" Class="@($"{Class} p-2")"
              GroupBy="@_groupDefinition"
              GroupFooterClass="mb-4">
        <ColGroup>
            <col />
            <col />
            <col />
            <col />
            <col />
        </ColGroup>
        <HeaderContent>
            <MudTh>عنوان</MudTh>
            <MudTh>قیمت</MudTh>
            <MudTh>تغییرات</MudTh>
            <MudTh>تاریخ بروزرسانی</MudTh>
        </HeaderContent>
        <GroupHeaderTemplate>
            <MudTh Class="mud-table-cell-custom-group" colspan="5">@($"{context.Key}")</MudTh>
        </GroupHeaderTemplate>
        <RowTemplate>
            <MudTd DataLabel="عنوان">
                <div class="align-center d-flex gap-1">
                    @if (context.HasIcon)
                    {
                        <MudAvatar Size="Size.Small">
                            <MudImage Src="@(ApiUrls.Icons.Get(IconType.Price, context.Id))" Alt="img"/>
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Size="Size.Small" Color="GetRandomColor()">
                            @context.Title.GetInitialsWithPeriods()
                        </MudAvatar>
                    }
                    @context.Title
                </div>
            </MudTd>
            <MudTd DataLabel="قیمت">@context.Value @context.Unit</MudTd>
            <MudTd DataLabel="تغییرات">
                @if (context.Change.Contains("-"))
                {
                    <div class="red-text">
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown"></MudIcon> @context.Change
                    </div>
                }
                else if (!context.Change.Contains("(0.00%)"))
                {
                    <div class="green-text">
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp"></MudIcon> @context.Change
                    </div>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Remove"></MudIcon> 
                    @context.Change
                }
            </MudTd>
            <MudTd DataLabel="تاریخ بروزرسانی">@context.LastUpdate</MudTd>
        </RowTemplate>
    </MudTable>
}

