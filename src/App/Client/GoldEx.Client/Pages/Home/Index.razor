@attribute [Route(ClientRoutes.Home.Index)]

@inherits GoldExComponentBase

<PageTitle>صفحه اصلی</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="px-0" Items="_breadcrumbs" MaxItems="2">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>
    <AuthorizeView>
        <NotAuthorized>
            <div class="row">
                <div class="col-12 col-md-8">
                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                        <MudText Typo="Typo.h4" Style="font-weight: 500" Class="mb-4">نرم افزار حسابداری طلا و جواهر گلدکس</MudText>
                    </MudHidden>
                    <div class="mb-4">
                        لطفا برای استفاده از امکانات سامانه، وارد حساب کاربری خود شوید
                    </div>
                </div>
                <div class="col-12 col-md-4 d-flex align-items-center justify-content-center justify-content-md-end mb-4">
                    <MudButton Href="@ClientRoutes.Accounts.Login" Variant="Variant.Filled" Color="Color.Primary">
                        ورود به حساب کاربری
                    </MudButton>
                </div>
            </div>
        </NotAuthorized>
    </AuthorizeView>

    <PriceBoard Class="d-block d-sm-none" Elevation="24" ShowTitle="true" ContainerClass="@PriceBoardClass" />

    <MudTabs Elevation="24" Rounded Centered
             Color="Color.Transparent"
             EnableDragAndDrop
             Class="d-sm-block d-none"
             Position="Position.Top">
        <MudTabPanel Text="نرخ لحظه ای" Icon="@Icons.Material.Filled.AttachMoney" IconColor="Color.Primary" Class="w-100">
            <PriceBoard Class="mt-5" Elevation="24" ContainerClass="@PriceBoardClass" />
        </MudTabPanel>
        <MudTabPanel Text="محاسبه گر" Icon="@Icons.Material.Outlined.Calculate"  Class="w-100">
            <Calculator Class="mt-5" Elevation="24" />
        </MudTabPanel>
        <AuthorizeView>
            <Authorized>
                <MudTabPanel Text="فاکتور ها" Icon="@Icons.Material.Filled.LibraryBooks" Class="w-100">
                    <InvoicesList Class="mt-5" Elevation="24" ContainerClass="responsive-table-toolbar" />
                </MudTabPanel>
                <MudTabPanel Text="اجناس من" Icon="@Icons.Material.Filled.Warehouse" Class="w-100">
                    <InventoryStockList Class="mt-5" Elevation="24" ContainerClass="responsive-table-toolbar" />
                </MudTabPanel>
                <MudTabPanel Text="مشتریان" Icon="@Icons.Material.Filled.PeopleAlt" Class="w-100">
                    <CustomersList Class="mt-5" Elevation="24" ContainerClass="responsive-table-toolbar" />
                </MudTabPanel>
                <MudTabPanel Text="اسناد پرداخت" Icon="@Icons.Material.Filled.Payment" Class="w-100">
                    <PaymentVouchersList Class="mt-5" Elevation="24" ContainerClass="responsive-table-toolbar" />
                </MudTabPanel>
            </Authorized>
        </AuthorizeView>
    </MudTabs>


</MudContainer>