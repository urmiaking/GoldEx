@using GoldEx.Client.Pages.Reporting.ViewModels

<EditForm Model="Model" OnValidSubmit="Submit">
    <DataAnnotationsValidator />

    <MudPaper Class="pa-4 mb-4" Elevation="24">
        <MudText Typo="Typo.h6">فیلتر گزارش</MudText>
        <MudGrid Spacing="3" Class="mt-0">
            <MudItem xs="12" sm="6" md="3">
                <MudDateRangePicker @bind-DateRange="@Model.DateRange"
                                    Margin="Margin.Dense"
                                    Variant="Variant.Outlined"
                                    MaxMonthColumns="1"
                                    DisplayMonths="1"
                                    Rounded="true"
                                    ShowToolbar="false"
                                    AnchorOrigin="Origin.BottomCenter"
                                    TransformOrigin="Origin.TopCenter"
                                    PlaceholderStart="از"
                                    PlaceholderEnd="تا"
                                    Elevation="24"
                                    RelativeWidth="DropdownWidth.Adaptive"
                                    Label="تاریخ گزارش"
                                    Clearable="true"/>
            </MudItem>

            @ChildContent

            <MudItem xs="12" md="2" Class="d-flex align-center justify-content-center justify-content-md-start">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Info"
                           ButtonType="ButtonType.Submit"
                           StartIcon="@Icons.Material.Filled.Search">
                    نمایش گزارش
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
</EditForm>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public ReportFilterVmBase Model { get; set; } = default!;
    [Parameter] public EventCallback<ReportFilterVmBase> OnSubmit { get; set; }

    private async Task Submit(EditContext editContext)
    {
        if (editContext.Validate())
        {
            await OnSubmit.InvokeAsync(Model);
        }
    }
}