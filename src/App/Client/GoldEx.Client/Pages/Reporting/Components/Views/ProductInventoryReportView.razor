@using GoldEx.Client.Pages.Reporting.Components.Summaries
@using GoldEx.Shared.DTOs.Reporting

@inherits GoldExComponentBase

@if (Items is null || IsLoading)
{
    if (IsLoading)
    {
        <div Class="d-flex flex-column justify-center align-center" style="height: 200px;">
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="w-100" />
            <MudText Typo="Typo.h6" Class="mt-4">در حال آماده سازی گزارش...</MudText>
        </div>
    }
    else
    {
        <ReportViewPlaceHolder />
    }
}
else
{
    <MudTable Items="@Items"
              Virtualize="true"
              Dense="true"
              Hover="true"
              Bordered="true"
              Striped="true"
              FixedHeader="true"
              Breakpoint="Breakpoint.Sm"
              SortLabel="مرتب ‌سازی"
              ContainerClass="responsive-table-toolbar"
              Elevation="24">
        <ToolBarContent>
            <MudText Typo="Typo.h6">گزارش موجودی کالا</MudText>
            <MudSpacer />
            <MudHidden Breakpoint="Breakpoint.MdAndDown">
                <MudButton StartIcon="@Icons.Material.Filled.Print"
                           Class="ml-2"
                           Color="Color.Success"
                           Variant="Variant.Filled"
                           OnClick="@(() => OnPrintReport.InvokeAsync())">
                    پرینت
                </MudButton>
            </MudHidden>
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudIconButton Icon="@Icons.Material.Filled.Print"
                               Color="Color.Success"
                               Variant="Variant.Filled"
                               OnClick="@(() => OnPrintReport.InvokeAsync())" />
            </MudHidden>
        </ToolBarContent>

        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<ProductInventoryRpResponse, object>(x => x.Product.Barcode)">
                    بارکد
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<ProductInventoryRpResponse, object>(x => x.Product.ProductType)">
                    نوع جنس
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<ProductInventoryRpResponse, object>(x => x.Product.ProductCategoryTitle ?? string.Empty)">
                    دسته
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<ProductInventoryRpResponse, object>(x => x.Product.Name)">
                    عنوان
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<ProductInventoryRpResponse, object>(x => x.Product.Wage ?? 0)">
                    اجرت
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<ProductInventoryRpResponse, object>(x => x.Product.Fineness)">
                    عیار
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<ProductInventoryRpResponse, object>(x => x.CurrentAmount)">
                    موجود
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<ProductInventoryRpResponse, object>(x => x.SoldAmount)">
                    فروخته شده
                </MudTableSortLabel>
            </MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="بارکد">@context.Product.Barcode</MudTd>
            <MudTd DataLabel="نوع جنس">@context.Product.ProductType.GetDisplayName()</MudTd>
            <MudTd DataLabel="دسته">@(context.Product.ProductCategoryTitle ?? "ندارد")</MudTd>
            <MudTd DataLabel="عنوان">@context.Product.Name</MudTd>
            <MudTd DataLabel="اجرت">@GetItemWage(context)</MudTd>
            <MudTd DataLabel="عیار">@context.Product.Fineness.ToString("G29")</MudTd>
            <MudTd DataLabel="موجود">@context.CurrentAmount.ToWeightFormat(context.Product.GoldUnitType)</MudTd>
            <MudTd DataLabel="فروخته شده">@context.SoldAmount.ToWeightFormat(context.Product.GoldUnitType)</MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">رکوردی برای نمایش وجود ندارد.</MudText>
        </NoRecordsContent>
    </MudTable>

    <ProductInventorySummary Summary="@_summary" />
}