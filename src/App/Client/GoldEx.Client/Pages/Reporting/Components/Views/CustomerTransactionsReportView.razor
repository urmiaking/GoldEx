@using GoldEx.Client.Pages.Reporting.Components.Summaries
@using GoldEx.Shared.DTOs.Reporting

@if (Items is null || IsLoading)
{
    if (IsLoading)
    {
        <div Class="d-flex flex-column justify-center align-center" style="height: 200px;">
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="w-100" />
            <MudText Typo="Typo.h6" Class="mt-4">در حال آماده سازی گزارش...</MudText>
        </div>
    }
    else
    {
        <ReportViewPlaceHolder />
    }
}
else
{
    <MudTable Items="Items"
              Dense="true"
              Hover="true"
              Bordered="true"
              Striped="true"
              FixedHeader="true"
              Virtualize="true"
              Breakpoint="Breakpoint.Sm"
              SortLabel="مرتب ‌سازی"
              ContainerClass="responsive-table-toolbar"
              Elevation="24">
        <ToolBarContent>
            <MudText Typo="Typo.h6">گزارش گردش حساب مشتری</MudText>
            <MudSpacer />
            <MudHidden Breakpoint="Breakpoint.MdAndDown">
                <MudButton StartIcon="@Icons.Material.Filled.Print"
                           Class="ml-2"
                           Color="Color.Success"
                           Variant="Variant.Filled"
                           OnClick="@(() => OnPrintReport.InvokeAsync())">
                    پرینت
                </MudButton>
            </MudHidden>
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudIconButton Icon="@Icons.Material.Filled.Print"
                               Color="Color.Success"
                               Variant="Variant.Filled"
                               OnClick="@(() => OnPrintReport.InvokeAsync())" />
            </MudHidden>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<CustomerTransactionRpResponse, object>(x => x.PostingDate)">
                    تاریخ
                </MudTableSortLabel>
            </MudTh>

            <MudTh>شرح</MudTh>

            <MudTh>
                <MudTableSortLabel SortBy="new Func<CustomerTransactionRpResponse, object>(x => x.Amount)">
                    مبلغ
                </MudTableSortLabel>
            </MudTh>

            <MudTh>
                <MudTableSortLabel SortBy="new Func<CustomerTransactionRpResponse, object>(x => x.ExchangeRate ?? 0m)">
                    نرخ تبدیل
                </MudTableSortLabel>
            </MudTh>

            <MudTh>
                <MudTableSortLabel SortBy="new Func<CustomerTransactionRpResponse, object>(x => x.BaseCurrencyAmount)">
                    مبلغ به ارز پایه
                </MudTableSortLabel>
            </MudTh>

            <MudTh>
                <MudTableSortLabel SortBy="new Func<CustomerTransactionRpResponse, object>(x => x.RunningBalance)">
                    مانده جاری
                </MudTableSortLabel>
            </MudTh>

            <MudTh>مرجع</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="تاریخ">@context.PostingDate.ToString("yyyy/MM/dd HH:mm")</MudTd>

            <MudTd DataLabel="شرح"><MudText Typo="Typo.body2">@context.Description</MudText></MudTd>

            <MudTd DataLabel="مبلغ">
                <div class="d-flex gap-2">
                    <MudIcon Icon="@GetTransactionIcon(context)" Color="@GetTransactionIconColor(context)" Size="Size.Small" />
                    <MudText Typo="Typo.body2">
                        @context.Amount.ToCurrencyFormat(context.PriceUnitTitle)
                    </MudText>
                </div>
            </MudTd>

            <MudTd DataLabel="نرخ تبدیل">
                @(context.ExchangeRate is null ? "-" : context.ExchangeRate.Value.ToCurrencyFormat())
            </MudTd>

            <MudTd DataLabel="مبلغ به ارز پایه">
                @context.BaseCurrencyAmount.ToString("N0")
            </MudTd>

            <MudTd DataLabel="مانده جاری">
                <MudText Typo="Typo.body2" Color="GetRunningBalanceColor(context)">
                    @Math.Abs(context.RunningBalance).ToCurrencyFormat(context.PriceUnitTitle)
                </MudText>
            </MudTd>

            <MudTd DataLabel="مرجع">
                <div class="d-flex gap-2">
                    @if (context.InvoiceId is not null)
                    {
                        <MudChip T="string"
                                 Text="فاکتور"
                                 Icon="@Icons.Material.Filled.Receipt"
                                 Size="Size.Small"
                                 Color="Color.Success"
                                 Variant="Variant.Filled"
                                 OnClick="@(() => OnOpenReference.InvokeAsync((nameof(context.InvoiceId), context.InvoiceId.Value)))" />
                    }
                    @if (context.PaymentVoucherId is not null)
                    {
                        <MudChip T="string"
                                 Text="سند پرداخت"
                                 Icon="@Icons.Material.Filled.RequestQuote"
                                 Size="Size.Small"
                                 Color="Color.Primary"
                                 Variant="Variant.Filled"
                                 OnClick="@(() => OnOpenReference.InvokeAsync((nameof(context.PaymentVoucherId), context.PaymentVoucherId.Value)))" />
                    }
                    @if (context.InvoicePaymentId is not null)
                    {
                        <MudChip T="string"
                                 Text="پرداخت فاکتور"
                                 Icon="@Icons.Material.Filled.Payments"
                                 Size="Size.Small"
                                 Color="Color.Info"
                                 Variant="Variant.Outlined" />
                    }
                </div>
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">رکوردی برای نمایش وجود ندارد.</MudText>
        </NoRecordsContent>
    </MudTable>

    <CustomerTransactionsSummary Summary="@_summary" />
}