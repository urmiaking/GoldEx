@using GoldEx.Client.Pages.Reporting.Components.Summaries
@using GoldEx.Shared.DTOs.Reporting

@inherits GoldExComponentBase

@if (Items is null || IsLoading)
{
    if (IsLoading)
    {
        <div Class="d-flex flex-column justify-center align-center" style="height: 200px;">
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="w-100" />
            <MudText Typo="Typo.h6" Class="mt-4">در حال آماده سازی گزارش...</MudText>
        </div>
    }
    else
    {
        <ReportViewPlaceHolder />
    }
}
else
{
    <MudTable Items="@Items"
              Virtualize="true"
              Dense="true"
              Hover="true"
              Bordered="true"
              Striped="true"
              FixedHeader="true"
              Breakpoint="Breakpoint.Sm"
              SortLabel="مرتب ‌سازی"
              ContainerClass="responsive-table-toolbar"
              Elevation="24">
        <ToolBarContent>
            <MudText Typo="Typo.h6">گزارش کاردکس کالا</MudText>
            <MudSpacer />
            <MudHidden Breakpoint="Breakpoint.MdAndDown">
                <MudButton StartIcon="@Icons.Material.Filled.Print"
                           Class="ml-2"
                           Color="Color.Success"
                           Variant="Variant.Filled"
                           OnClick="@(() => OnPrintReport.InvokeAsync())">
                    پرینت
                </MudButton>
            </MudHidden>
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudIconButton Icon="@Icons.Material.Filled.Print"
                               Color="Color.Success"
                               Variant="Variant.Filled"
                               OnClick="@(() => OnPrintReport.InvokeAsync())" />
            </MudHidden>
        </ToolBarContent>

        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<InventoryKardexRpResponse, object>(x => x.DateTime)">
                    تاریخ
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<InventoryKardexRpResponse, object>(x => x.Amount)">
                    مقدار
                </MudTableSortLabel>
            </MudTh>
            <MudTh>شرح</MudTh>
            <MudTh>عملیات</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="تاریخ">
                <MudTooltip Text="@context.DateTime.ToString("yyyy/MM/dd HH:mm:ss")" Arrow="true" Placement="Placement.Top">
                    @context.DateTime.ToString("yyyy/MM/dd")
                </MudTooltip>
            </MudTd>
            <MudTd DataLabel="مقدار">
                <div class="d-flex gap-2">
                    <MudIcon Icon="@GetIcon(context)" Color="@GetColor(context)" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Color="GetColor(context)">@GetAmount(context)</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="شرح">@context.Description</MudTd>
            <MudTd DataLabel="عملیات">
                @if (!string.IsNullOrEmpty(context.SourceUrl))
                {
                    <div class="d-flex gap-2">
                        <MudButton Size="@Size.Small"
                                   Variant="@Variant.Filled" 
                                   EndIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="() => OnViewSource(context.SourceUrl)"
                                   Color="@GetActionColor(context.SourceUrl)">
                            @GetActionText(context.SourceUrl)
                        </MudButton>
                    </div>
                }
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">رکوردی برای نمایش وجود ندارد.</MudText>
        </NoRecordsContent>
    </MudTable>

    <InventoryKardexSummary Summary="@_summary" />
}