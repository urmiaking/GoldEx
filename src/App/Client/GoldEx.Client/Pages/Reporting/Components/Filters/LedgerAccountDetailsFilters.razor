@inherits GoldExComponentBase

<MudItem xs="12" sm="6" md="3">
    <MudAutocomplete T="Guid?"  
                     Label="@Model.GetDisplayName(() => Model.LedgerAccountId)"  
                     Value="Model.LedgerAccountId"  
                     ValueChanged="OnLedgerAccountChanged"  
                     Dense="true"  
                     For="@(() => Model.LedgerAccountId)"  
                     Variant="Variant.Outlined"  
                     Margin="Margin.Dense"  
                     Required="true"
                     MaxItems="100"
                     SearchFunc="SearchLedgerAccounts"  
                     ToStringFunc="GetLedgerAccountDisplayText"  
                     CoerceText="true" />
</MudItem>

<MudItem xs="12" sm="6" md="3">
    <MudSelect T="Guid?"
               Label="@Model.GetDisplayName(() => Model.PriceUnitId)"
               @bind-Value="Model.PriceUnitId"
               Disabled="@(!Model.LedgerAccountId.HasValue)"
               For="@(() => Model.PriceUnitId)"
               Variant="Variant.Outlined"
               Margin="Margin.Dense">
        <MudSelectItem T="Guid?" Value="@((Guid?)null)">همه ارزها</MudSelectItem>
        @foreach (var item in _priceUnits)
        {
            <MudSelectItem Value="item.Id" T="Guid?">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Size="Size.Small">
                        <MudImage Src="@(ApiUrls.Icons.Get(IconType.PriceUnit, item.Id))" Alt="@item.Title" />
                    </MudAvatar>
                    <MudText>@item.Title</MudText>
                </MudStack>
            </MudSelectItem>
        }
    </MudSelect>
</MudItem>