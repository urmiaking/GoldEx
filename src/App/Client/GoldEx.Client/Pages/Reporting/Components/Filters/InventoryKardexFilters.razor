@inherits GoldExComponentBase

<MudItem xs="12" sm="6" md="3">
    <div class="d-flex flex-row align-center gap-2">
        <MudTextField T="string?"
                      Value="@_selectedItem"
                      Immediate
                      ReadOnly
                      Required
                      Clearable
                      OnClearButtonClick="OnCleared"
                      RequiredError="لطفا کالا را انتخاب کنید"
                      Margin="Margin.Dense"
                      Label="عنوان کالا"
                      Variant="Variant.Outlined"
                      OnAdornmentClick="OpenInventorySelector" />
        <MudIconButton Icon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Color="Color.Primary" OnClick="OpenInventorySelector" />
    </div>
</MudItem>