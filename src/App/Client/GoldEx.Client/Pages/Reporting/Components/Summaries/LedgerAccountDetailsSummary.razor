@using GoldEx.Client.Pages.Reporting.ViewModels
@if (Summary != null)  
{  
    <MudCard Elevation="24" Class="mt-4">  
        <MudCardHeader>  
            <CardHeaderContent>  
                <MudText Typo="Typo.h6">خلاصه گزارش</MudText>  
            </CardHeaderContent>  
        </MudCardHeader>  
        <MudCardContent>  
            @if (Summary.PriceUnitSummaries.Any())  
            {  
                <MudGrid Spacing="6">  
                    @foreach (var priceUnit in Summary.PriceUnitSummaries)  
                    {  
                        <MudItem xs="12" sm="6" md="4">  
                            <MudCard Elevation="12">  
                                <MudCardHeader Class="pa-3">  
                                    <CardHeaderContent>  
                                        <div class="d-flex justify-content-between align-center">
                                            <MudText Typo="Typo.h5" Color="Color.Primary">@priceUnit.PriceUnitTitle</MudText>
                                            @if (!string.IsNullOrEmpty(priceUnit.ExchangeRateInfo))  
                                            {  
                                                <MudText Typo="Typo.body2" Color="Color.Info">@priceUnit.ExchangeRateInfo</MudText>  
                                            }  
                                        </div>
                                    </CardHeaderContent>  
                                </MudCardHeader>  
                                <MudCardContent Class="pa-3">  
                                    <MudStack Spacing="2">  
                                        <div class="d-flex justify-space-between align-center">  
                                            <MudText Typo="Typo.body1">مجموع بدهکار:</MudText>  
                                            <MudText Typo="Typo.body1" Color="Color.Error">  
                                                <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" Class="ml-1" />  
                                                @priceUnit.TotalDebit.ToCurrencyFormat(priceUnit.PriceUnitTitle)  
                                            </MudText>  
                                        </div>  
                                        <div class="d-flex justify-space-between align-center">
                                            <MudText Typo="Typo.body1">مجموع بستانکار:</MudText>
                                            <MudText Typo="Typo.body1" Color="Color.Success">
                                                <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" Class="ml-1" />  
                                                @priceUnit.TotalCredit.ToCurrencyFormat(priceUnit.PriceUnitTitle)  
                                            </MudText>  
                                        </div>  
                                        <MudDivider Class="my-2" />  
                                        <div class="d-flex justify-space-between align-center">
                                            <MudText Typo="Typo.body1">خالص:</MudText>
                                            @{
                                                var net = priceUnit.TotalDebit - priceUnit.TotalCredit;
                                                var netColor = net >= 0 ? Color.Error : Color.Success;
                                                var netIcon = net >= 0 ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward;
                                                var netText = net >= 0 ? "بدهکار" : "بستانکار";
                                            }
                                            <MudText Typo="Typo.body1" Color="@netColor">
                                                <MudIcon Icon="@netIcon" Size="Size.Small" Class="ml-1" />  
                                                @Math.Abs(net).ToCurrencyFormat(priceUnit.PriceUnitTitle) @netText  
                                            </MudText>  
                                        </div>  
                                    </MudStack>  
                                </MudCardContent>  
                            </MudCard>  
                        </MudItem>  
                    }  
                </MudGrid>  
            }  
  
            @if (Summary.ShowTotalBaseCurrencySummary)  
            {  
                <MudCard Elevation="24" Class="mt-6">  
                    <MudCardHeader Class="pa-3">  
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Color="Color.Primary">جمع کل (ارز پایه)</MudText>
                        </CardHeaderContent>  
                    </MudCardHeader>  
                    <MudCardContent Class="pa-3">  
                        <MudGrid Spacing="2">  
                            <MudItem xs="12" sm="4">  
                                <MudPaper Class="pa-3 text-center" Elevation="0">  
                                    <MudText Typo="Typo.body2" Color="Color.Error">  
                                        <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" />  
                                    </MudText>  
                                    <MudText Typo="Typo.h6" Color="Color.Error">@Summary.TotalBaseCurrencyDebit.ToString("N0")</MudText>  
                                    <MudText Typo="Typo.body1">مجموع بدهکار</MudText>  
                                </MudPaper>  
                            </MudItem>  
                            <MudItem xs="12" sm="4">  
                                <MudPaper Class="pa-3 text-center" Elevation="0">  
                                    <MudText Typo="Typo.body2" Color="Color.Success">  
                                        <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" />  
                                    </MudText>  
                                    <MudText Typo="Typo.h6" Color="Color.Success">@Summary.TotalBaseCurrencyCredit.ToString("N0")</MudText>
                                    <MudText Typo="Typo.body1">مجموع بستانکار</MudText>
                                </MudPaper>  
                            </MudItem>  
                            <MudItem xs="12" sm="4">  
                                <MudPaper Class="pa-3 text-center" Elevation="0">  
                                    @{  
                                        var totalNet = Summary.TotalBaseCurrencyDebit - Summary.TotalBaseCurrencyCredit;  
                                        var totalNetColor = totalNet >= 0 ? Color.Error : Color.Success;  
                                        var totalNetIcon = totalNet >= 0 ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward;  
                                        var totalNetText = totalNet >= 0 ? "بدهکار" : "بستانکار";  
                                    }  
                                    <MudText Typo="Typo.body2" Color="@totalNetColor">  
                                        <MudIcon Icon="@totalNetIcon" Size="Size.Small" />  
                                    </MudText>  
                                    <MudText Typo="Typo.h6" Color="@totalNetColor">@Math.Abs(totalNet).ToString("N0")</MudText>
                                    <MudText Typo="Typo.body1">@totalNetText</MudText>
                                </MudPaper>  
                            </MudItem>  
                        </MudGrid>  
                    </MudCardContent>  
                </MudCard>  
            }  
        </MudCardContent>  
    </MudCard>  
}  
  
@code {  
    [Parameter] public LedgerAccountDetailsFilterVm.LedgerAccountDetailsReportSummary? Summary { get; set; }
}