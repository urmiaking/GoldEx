@using GoldEx.Client.Pages.Reporting.ViewModels

@if (Summary != null)
{
    <MudCard Elevation="24" Class="mt-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">خلاصه گزارش</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (Summary != null)
            {
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Elevation="0">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Large" Color="Color.Error" />
                            <MudText Typo="Typo.h5" Color="Color.Error">@Summary.TotalPaidAmount.ToCurrencyFormat(Summary.PriceUnit)</MudText>
                            <MudText Typo="Typo.h6">مجموع پرداختی</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Elevation="0">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Large" Color="Color.Success" />
                            <MudText Typo="Typo.h5" Color="Color.Success">@Summary.TotalReceivedAmount.ToCurrencyFormat(Summary.PriceUnit)</MudText>
                            <MudText Typo="Typo.h6">مجموع دریافتی</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Elevation="0">
                            <MudIcon Icon="@GetRemainingIcon(Summary.InvoiceRemainingPrice)" Size="Size.Large" Color="GetRemainingColor(Summary.InvoiceRemainingPrice)" />
                            <MudText Typo="Typo.h5" Color="GetRemainingColor(Summary.InvoiceRemainingPrice)">
                                @GetRemainingAmount(Summary)
                            </MudText>
                            <MudText Typo="Typo.h6">مانده فاکتور</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter] public InvoicePaymentFilterVm.InvoicePaymentReportSummary? Summary { get; set; }

    private string GetRemainingIcon(decimal amount)
    {
        return amount switch
        {
            0 => Icons.Material.Outlined.SwapHoriz,
            > 0 => Icons.Material.Outlined.ArrowUpward,
            < 0 => Icons.Material.Outlined.ArrowDownward
        };
    }

    private Color GetRemainingColor(decimal amount)
    {
        return amount switch
        {
            0 => Color.Default,
            > 0 => Color.Error,
            < 0 => Color.Success
        };
    }

    private string GetRemainingAmount(InvoicePaymentFilterVm.InvoicePaymentReportSummary summary)
    {
        return summary.InvoiceRemainingPrice switch
        {
            0 => "تسویه",
            > 0 or < 0 => $"{summary.InvoiceRemainingPrice.ToCurrencyFormat(summary.PriceUnit)}"
        };
    }
}