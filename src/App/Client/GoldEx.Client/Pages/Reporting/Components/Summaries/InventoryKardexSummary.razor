@using GoldEx.Client.Pages.Reporting.ViewModels

@if (Summary != null)
{
    <MudCard Elevation="24" Class="mt-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">خلاصه گزارش</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (Summary != null)
            {
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Elevation="0">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Large" Color="Color.Success" />
                            <MudText Typo="Typo.h5" Color="Color.Success">@Summary.TotalIn.ToCurrencyFormat(Summary.Unit)</MudText>
                            <MudText Typo="Typo.h6">مجموع ورود</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Elevation="0">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Large" Color="Color.Error" />
                            <MudText Typo="Typo.h5" Color="Color.Error">@Summary.TotalOut.ToCurrencyFormat(Summary.Unit)</MudText>
                            <MudText Typo="Typo.h6">مجموع خروج</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-3 text-center" Elevation="0">
                            <MudIcon Icon="@GetRemainingIcon(Summary.TotalRemaining)" Size="Size.Large" Color="GetRemainingColor(Summary.TotalRemaining)" />
                            <MudText Typo="Typo.h5" Color="GetRemainingColor(Summary.TotalRemaining)">
                                @GetRemainingAmount(Summary)
                            </MudText>
                            <MudText Typo="Typo.h6">مانده</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter] public InventoryKardexFilterVm.InventoryKardexReportSummary? Summary { get; set; }

    private string GetRemainingIcon(decimal amount)
    {
        return amount switch
        {
            0 => Icons.Material.Outlined.SwapHoriz,
            > 0 => Icons.Material.Outlined.Check,
            < 0 => Icons.Material.Outlined.Close
        };
    }

    private Color GetRemainingColor(decimal amount)
    {
        return amount switch
        {
            0 => Color.Default,
            > 0 => Color.Success,
            < 0 => Color.Error
        };
    }

    private string GetRemainingAmount(InventoryKardexFilterVm.InventoryKardexReportSummary summary)
    {
        return summary.TotalRemaining switch
        {
            0 => "صفر",
            > 0 or < 0 => $"{summary.TotalRemaining.ToCurrencyFormat(summary.Unit)}"
        };
    }
}