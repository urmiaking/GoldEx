@attribute [Route(ClientRoutes.Reporting.CustomerBalances)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

@inherits CustomerBalancePageBase

<PageTitle>مانده مشتریان</PageTitle>
<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="pr-0" Items="Breadcrumbs" MaxItems="2">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>

    <ReportFiltersBase Model="@Filters" OnSubmit="OnSubmit">
        <CustomerBalanceFilters Model="@Filters" />
    </ReportFiltersBase>

    <CustomerBalanceReportView Items="@Data" IsLoading="@IsLoading" OnPrintReport="PrintReport" />
</MudContainer>

<script src="/js/report-print.js?v=2"></script>