@attribute [Route(ClientRoutes.Reporting.CustomerTransactions)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

@inherits CustomerTransactionsPageBase

<PageTitle>گردش حساب مشتری</PageTitle>
<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="px-0" Items="Breadcrumbs" MaxItems="2">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>

    <ReportFiltersBase Model="@Filters" OnSubmit="OnSubmit">
        <CustomerTransactionFilters Model="@Filters" />
    </ReportFiltersBase>

    <CustomerTransactionsReportView Items="@Data" IsLoading="@IsLoading" OnPrintReport="PrintReport" OnOpenReference="OpenReference" />
</MudContainer>

<script src="/js/report-print.js?v=2"></script>