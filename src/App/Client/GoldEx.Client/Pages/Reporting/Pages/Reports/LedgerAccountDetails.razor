@attribute [Route(ClientRoutes.Reporting.LedgerAccountDetails)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

@using GoldEx.Client.Pages.Reporting.Components.Filters
@using GoldEx.Client.Pages.Reporting.Components.Views
@using GoldEx.Client.Pages.Reporting.Pages.Base

@inherits LedgerAccountDetailsPageBase

<PageTitle>گردش حساب</PageTitle>
<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="pr-0" Items="Breadcrumbs">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>

    <ReportFiltersBase Model="@Filters" OnSubmit="OnSubmit">
        <LedgerAccountDetailsFilters Model="@Filters" />
    </ReportFiltersBase>

    <LedgerAccountDetailsReportView Items="@Data" IsLoading="@IsLoading" OnPrintReport="PrintReport" OnOpenReference="OpenReference" />
</MudContainer>

<script src="/js/report-print.js?v=2"></script>