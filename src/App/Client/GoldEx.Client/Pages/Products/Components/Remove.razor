@inherits GoldExComponentBase

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">
            شرایط حذف جنس @ProductName
        </MudText>

        <MudPaper Class="p-3 rounded-lg" Elevation="1">
            <MudList T="string" Dense="true">
                <MudListItem 
                    Text="تنها اجناسی که از طریق موجودی اولیه به صورت دستی وارد شده‌اند قابلیت حذف دارند."
                    Icon="@Icons.Material.Filled.Info"
                    IconColor="Color.Warning" />

                <MudListItem 
                    Text="برای حذف اجناسی که از طریق فاکتور خرید وارد شده‌اند باید جنس را از فاکتور خرید مربوطه حذف کنید."
                    Icon="@Icons.Material.Filled.ReceiptLong"
                    IconColor="Color.Primary" />

                <MudListItem
                    Text="اجناسی که همه یا بخشی از آن فروخته شده است امکان حذف ندارند."
                    Icon="@Icons.Material.Filled.Block"
                    IconColor="Color.Error" />

                <MudListItem
                    Text="این عملیات غیرقابل برگشت است."
                    Icon="@Icons.Material.Filled.WarningAmber"
                    IconColor="Color.Error"
                    SecondaryText="قبل از ادامه از صحت عملیات مطمئن شوید." />
            </MudList>
        </MudPaper>

        <MudText Class="mt-3 text-center" Color="Color.Error">
            با تأیید، سیستم بررسی می‌کند که آیا شرایط بالا برقرار است یا خیر.
        </MudText>

    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">
            لغو
        </MudButton>

        <MudButton Class="m-3"
                   Color="Color.Error"
                   Disabled="@IsBusy"
                   StartIcon="@Icons.Material.Filled.Delete"
                   OnClick="@(async () => await OnValidSubmit())"
                   Variant="Variant.Filled">

            @if (IsBusy)
            {
                <MudProgressCircular Class="ms-n1"
                                     Size="Size.Small"
                                     Indeterminate="true" />
                <MudText Class="ms-2">در حال حذف</MudText>
            }
            else
            {
                <MudText>تأیید حذف</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>
