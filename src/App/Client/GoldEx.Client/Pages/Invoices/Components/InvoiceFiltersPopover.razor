<MudOverlay Visible="@Open"
            DarkBackground="true">
    <MudPopover Open="Open"
                Class="pa-3 responsive-popover"
                Fixed="true"
                AnchorOrigin="Origin.CenterCenter"
                TransformOrigin="Origin.CenterCenter"
                Elevation="6">
        <MudStack Spacing="2" Class="w-100">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.subtitle1">فیلترها</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="OnClose" />
            </MudStack>

            <!-- Invoice Type -->
            <MudSelect T="InvoiceType?"
                       Variant="Variant.Outlined"
                       Label="نوع فاکتور"
                       Value="@_invoiceType"
                       ValueChanged="@(v => _invoiceType = v)"
                       Dense="true"
                       Margin="Margin.Dense"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@GetInvoiceTypeIcon(_invoiceType)"
                       AdornmentColor="@GetInvoiceTypeColor(_invoiceType)"
                       Class="w-100">
                <MudSelectItem T="InvoiceType?" Value="@(null as InvoiceType?)">همه</MudSelectItem>
                <MudSelectItem T="InvoiceType?" Value="@InvoiceType.Purchase">@InvoiceType.Purchase.GetDisplayName()</MudSelectItem>
                <MudSelectItem T="InvoiceType?" Value="@InvoiceType.Sell">@InvoiceType.Sell.GetDisplayName()</MudSelectItem>
            </MudSelect>

            <!-- Trade Scale -->
            <MudSelect T="TradeScale?"
                       Variant="Variant.Outlined"
                       Label="نوع معامله"
                       Value="@_tradeScale"
                       ValueChanged="@(v => _tradeScale = v)"
                       Dense="true"
                       Margin="Margin.Dense"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@GetTradeScaleIcon(_tradeScale)"
                       AdornmentColor="@GetTradeScaleColor(_tradeScale)"
                       Class="w-100">
                <MudSelectItem T="TradeScale?" Value="@(null as TradeScale?)">همه</MudSelectItem>
                <MudSelectItem T="TradeScale?" Value="@TradeScale.Wholesale">@TradeScale.Wholesale.GetDisplayName()</MudSelectItem>
                <MudSelectItem T="TradeScale?" Value="@TradeScale.Retail">@TradeScale.Retail.GetDisplayName()</MudSelectItem>
            </MudSelect>

            <!-- Payment Status -->
            <MudSelect T="InvoicePaymentStatus?"
                       Variant="Variant.Outlined"
                       Label="وضعیت پرداخت"
                       Value="@_paymentStatus"
                       ValueChanged="@(v => _paymentStatus = v)"
                       Dense="true"
                       Margin="Margin.Dense"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@GetPaymentStatusIcon(_paymentStatus)"
                       AdornmentColor="@GetPaymentStatusColor(_paymentStatus)"
                       Class="w-100">
                <MudSelectItem T="InvoicePaymentStatus?" Value="@(null as InvoicePaymentStatus?)">همه</MudSelectItem>
                <MudSelectItem T="InvoicePaymentStatus?" Value="@InvoicePaymentStatus.HasDebt">@InvoicePaymentStatus.HasDebt.GetDisplayName()</MudSelectItem>
                <MudSelectItem T="InvoicePaymentStatus?" Value="@InvoicePaymentStatus.Overdue">@InvoicePaymentStatus.Overdue.GetDisplayName()</MudSelectItem>
                <MudSelectItem T="InvoicePaymentStatus?" Value="@InvoicePaymentStatus.Paid">@InvoicePaymentStatus.Paid.GetDisplayName()</MudSelectItem>
            </MudSelect>

            <!-- Date range -->
            <MudDateRangePicker DateRange="@_dateRange"
                                DateRangeChanged="@(dr => _dateRange = dr)"
                                Variant="Variant.Outlined"
                                Label="تاریخ فاکتور"
                                Margin="Margin.Dense"
                                MaxMonthColumns="1"
                                DisplayMonths="1"
                                Adornment="Adornment.Start"
                                ShowToolbar="false"
                                Clearable="true"
                                Class="w-100" />

            <!-- Actions -->
            <MudStack Row="true" Spacing="1" Class="mt-3" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           OnClick="Clear"
                           StartIcon="@Icons.Material.Filled.Delete">
                    حذف فیلترها
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           OnClick="Apply"
                           StartIcon="@Icons.Material.Filled.Check">
                    اعمال
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPopover>
</MudOverlay>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    [Parameter] public DateRange DateRange { get; set; } = new();
    [Parameter] public InvoiceType? InvoiceTypeParam { get; set; }
    [Parameter] public TradeScale? TradeScaleParam { get; set; }
    [Parameter] public InvoicePaymentStatus? PaymentStatus { get; set; }

    [Parameter] public EventCallback<InvoicesList.InvoicesMobileFiltersResult> OnApply { get; set; }

    private DateRange _dateRange = new();
    private InvoiceType? _invoiceType;
    private TradeScale? _tradeScale;
    private InvoicePaymentStatus? _paymentStatus;

    protected override void OnParametersSet()
    {
        _dateRange = new DateRange(DateRange.Start, DateRange.End);
        _invoiceType = InvoiceTypeParam;
        _tradeScale = TradeScaleParam;
        _paymentStatus = PaymentStatus;
    }

    private string GetInvoiceTypeIcon(InvoiceType? type) => type switch
    {
        InvoiceType.Purchase => Icons.Material.Filled.ArrowUpward,
        InvoiceType.Sell => Icons.Material.Filled.ArrowDownward,
        null => Icons.Material.Filled.CompareArrows,
        _ => Icons.Material.Filled.Help
    };

    private Color GetInvoiceTypeColor(InvoiceType? type) => type switch
    {
        InvoiceType.Purchase => Color.Success,
        InvoiceType.Sell => Color.Error,
        null => Color.Info,
        _ => Color.Default
    };

    private string GetTradeScaleIcon(TradeScale? scale) => scale switch
    {
        TradeScale.Wholesale => Icons.Material.Filled.Apps,
        TradeScale.Retail => Icons.Material.Filled.Square,
        null => Icons.Material.Filled.ViewHeadline,
        _ => Icons.Material.Filled.Help
    };

    private Color GetTradeScaleColor(TradeScale? scale) => scale switch
    {
        TradeScale.Wholesale => Color.Primary,
        TradeScale.Retail => Color.Success,
        null => Color.Info,
        _ => Color.Default
    };

    private string GetPaymentStatusIcon(InvoicePaymentStatus? status) => status switch
    {
        InvoicePaymentStatus.Paid => Icons.Material.Filled.Check,
        InvoicePaymentStatus.HasDebt => Icons.Material.Filled.Pending,
        InvoicePaymentStatus.Overdue => Icons.Material.Filled.MoreTime,
        null => Icons.Material.Filled.ViewHeadline,
        _ => Icons.Material.Filled.Help
    };

    private Color GetPaymentStatusColor(InvoicePaymentStatus? status) => status switch
    {
        InvoicePaymentStatus.Paid => Color.Success,
        InvoicePaymentStatus.HasDebt => Color.Primary,
        InvoicePaymentStatus.Overdue => Color.Error,
        null => Color.Info,
        _ => Color.Default
    };

    private async Task Apply()
    {
        var result = new InvoicesList.InvoicesMobileFiltersResult(
            new DateRange(_dateRange.Start, _dateRange.End),
            _invoiceType,
            _tradeScale,
            _paymentStatus
        );

        await OnApply.InvokeAsync(result);
    }

    private async Task Clear()
    {
        _dateRange = new DateRange();
        _invoiceType = null;
        _tradeScale = null;
        _paymentStatus = null;
        await Apply();
    }
}