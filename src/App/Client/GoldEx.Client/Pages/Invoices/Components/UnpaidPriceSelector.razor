@using GoldEx.Shared.DTOs.PriceUnits
@inherits GoldExComponentBase

<div class="d-flex flex-column gap-3">
    <MudText>نوع بدهی</MudText>
    @* Bind directly to the new `SelectedMode` property *@
    <MudRadioGroup T="string" @bind-Value="SelectedMode">
        <MudRadio Value="@("main")" Color="Color.Primary">
            ارز اصلی فاکتور (@MainPriceUnit?.Title)
        </MudRadio>
        <MudRadio Value="@("custom")" Color="Color.Primary">
            ارز سفارشی
        </MudRadio>
    </MudRadioGroup>

    @if (SelectedMode == "custom")
    {
        <MudGrid>
            <MudItem xs="12">
                @* Bind directly to the property that handles the two-way binding logic *@
                <MudSelect T="GetPriceUnitTitleResponse" Variant="Variant.Outlined"
                           Margin="Margin.Dense" Label="واحد ارز"
                           @bind-Value="BoundUnpaidPriceUnit" Dense="true">
                    @foreach (var item in PriceUnits)
                    {
                        <MudSelectItem Value="item">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                <MudAvatar Size="Size.Small">
                                    <MudImage Src="@(ApiUrls.Icons.Get(IconType.PriceUnit, item.Id))" Alt="@item.Title" />
                                </MudAvatar>
                                <MudText>@item.Title</MudText>
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            @if (UnpaidPriceUnit is not null && MainPriceUnit is not null)
            {
                <MudItem xs="12">
                    <MudNumericField T="decimal?"
                                     @bind-Value="BoundDisplayExchangeRate"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Label="@RateLabel"
                                     Format="@RateNumericFormat"
                                     Adornment="Adornment.End"
                                     AdornmentText="@AdornmentText"
                                     Immediate="true"
                                     HideSpinButtons="true"
                                     dir="ltr" />
                    <div class="d-flex justify-content-center">
                        <MudText Typo="Typo.caption" Class="mt-1" Color="Color.Primary">
                            @HelperText
                        </MudText>
                    </div>
                </MudItem>
            }
        </MudGrid>
    }

    <MudDivider />

    <div class="d-flex flex-column align-center mt-2">
        @if (SelectedMode == "main")
        {
            <MudText Color="Color.Primary" Typo="Typo.h6">
                مبلغ کل: @TotalUnpaidAmount.ToCurrencyFormat(MainPriceUnit?.Title)
            </MudText>
        }
        else if (UnpaidPriceUnit is not null)
        {
            <MudText Color="Color.Primary" Typo="Typo.h6">
                مبلغ کل: @ComputedSecondaryDisplay.ToCurrencyFormat(SecondaryUnitTitle)
            </MudText>
            @if (ShowMainEquivalent)
            {
                <MudText Color="Color.Primary" Typo="Typo.body2">
                    (معادل @TotalUnpaidAmount.ToCurrencyFormat(MainPriceUnit?.Title))
                </MudText>
            }
        }
    </div>
</div>