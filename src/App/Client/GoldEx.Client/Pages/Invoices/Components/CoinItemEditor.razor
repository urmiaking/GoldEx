@using GoldEx.Shared.DTOs.Coins
@inherits GoldExComponentBase

<MudForm Model="Model" @ref="@_form" Validation="@(_coinItemValidator.ValidateValue)" ValidationDelay="0">
    <MudDialog>
        <DialogContent>
            <div class="align-center d-flex flex-wrap gap-md-3 justify-center justify-md-space-between mb-1">
                <div class="d-flex flex-wrap align-center gap-3 my-3">
                    <MudText Typo="Typo.body1" Class="d-none d-md-block">نوع سکه:</MudText>
                    <MudChipSet T="CoinMintType"
                                SelectionMode="SelectionMode.SingleSelection"
                                Variant="Variant.Outlined"
                                Size="Size.Medium"
                                CheckMark="true"
                                SelectedValue="Model.CoinMintType"
                                SelectedValueChanged="OnCoinMintTypeChanged">
                        <MudChip Color="Color.Success"
                                 Value="CoinMintType.Banking"
                                 Size="@(Model.CoinMintType == CoinMintType.Banking ? Size.Large : Size.Medium)"
                                 Variant="@(Model.CoinMintType == CoinMintType.Banking ? Variant.Text : Variant.Outlined)">@CoinMintType.Banking.GetDisplayName()</MudChip>
                        <MudChip Color="Color.Error"
                                 Value="CoinMintType.NonBanking"
                                 Size="@(Model.CoinMintType == CoinMintType.NonBanking ? Size.Large : Size.Medium)"
                                 Variant="@(Model.CoinMintType == CoinMintType.NonBanking ? Variant.Text : Variant.Outlined)">@CoinMintType.NonBanking.GetDisplayName()</MudChip>
                    </MudChipSet>
                </div>
                <div class="d-flex flex-wrap align-center gap-3 my-3">
                    <MudText Typo="Typo.body1" Class="d-none d-md-block">نوع بسته بندی:</MudText>
                    <MudChipSet T="CoinPackageType"
                                SelectionMode="SelectionMode.SingleSelection"
                                Variant="Variant.Outlined"
                                Size="Size.Medium"
                                CheckMark="true"
                                SelectedValue="Model.CoinPackageType"
                                SelectedValueChanged="OnCoinPackageTypeChanged">
                        <MudChip Color="Color.Success"
                                 Value="CoinPackageType.VacuumSealed"
                                 Size="@(Model.CoinPackageType == CoinPackageType.VacuumSealed ? Size.Large : Size.Medium)"
                                 Variant="@(Model.CoinPackageType == CoinPackageType.VacuumSealed ? Variant.Text : Variant.Outlined)">@CoinPackageType.VacuumSealed.GetDisplayName()</MudChip>
                        <MudChip Color="Color.Error"
                                 Value="CoinPackageType.Open"
                                 Size="@(Model.CoinPackageType == CoinPackageType.Open ? Size.Large : Size.Medium)"
                                 Variant="@(Model.CoinPackageType == CoinPackageType.Open ? Variant.Text : Variant.Outlined)">@CoinPackageType.Open.GetDisplayName()</MudChip>
                    </MudChipSet>
                </div>
            </div>
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6" lg="4">
                    <MudSelect T="GetCoinResponse?"
                               Value="Model.Coin"
                               ValueChanged="OnCoinChanged"
                               Label="@Model.GetDisplayName(() => Model.Coin)"
                               For="() => Model.Coin"
                               Margin="Margin.Dense"
                               Variant="Variant.Outlined">
                        <MudSelectItem T="GetCoinResponse?" Value="null">انتخاب کنید...</MudSelectItem>
                        @foreach (var item in _coins)
                        {
                            <MudSelectItem Value="item">@item.Title</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6" lg="4">
                    <MudNumericField T="decimal"
                                     @bind-Value="Model.UnitPrice"
                                     Label="@Model.GetDisplayName(() => Model.UnitPrice)"
                                     For="() => Model.UnitPrice"
                                     Format="#,##0.##"
                                     dir="ltr"
                                     Immediate="true"
                                     HideSpinButtons="true"
                                     Margin="Margin.Dense"
                                     Variant="Variant.Outlined"
                                     InputMode="InputMode.numeric"
                                     Adornment="Adornment.End"
                                     AdornmentText="@PriceUnit?.Title" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <div class="d-flex align-center gap-2">
                        <MudIconButton Icon="@Icons.Material.Filled.Remove" Variant="Variant.Outlined"
                                       OnClick="@(() => Model.Quantity--)"
                                       Disabled="@(Model.Quantity <= 1)"
                                       Color="Color.Primary" />

                        <MudNumericField For="@(() => Model.Quantity)"
                                         Immediate="true"
                                         dir="ltr"
                                         Label="@Model.GetDisplayName(() => Model.Quantity)"
                                         Margin="Margin.Dense"
                                         T="int"
                                         Min="0"
                                         Max="GetMaxAmount()"
                                         @bind-Value="Model.Quantity"
                                         HideSpinButtons="true"
                                         Variant="Variant.Outlined"
                                         Style="flex: 1;" />

                        <MudIconButton Icon="@Icons.Material.Filled.Add" Variant="Variant.Outlined"
                                       OnClick="@(() => Model.Quantity++)"
                                       Color="Color.Primary" />
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudNumericField Adornment="Adornment.End"
                                     AdornmentText="@GoldUnitType.Gram.GetDisplayName()"
                                     For="() => Model.Weight"
                                     dir="ltr"
                                     Disabled="Model.CoinMintType == CoinMintType.Banking"
                                     Format="G29"
                                     Immediate="true"
                                     HideSpinButtons="true"
                                     Margin="Margin.Dense"
                                     Label="@(Model.GetDisplayName(() => Model.Weight))"
                                     T="decimal?"
                                     @bind-Value="Model.Weight"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudNumericField For="@(() => Model.Fineness)"
                                     Format="G29"
                                     Immediate="true"
                                     dir="ltr"
                                     Label="@Model.GetDisplayName(() => Model.Fineness)"
                                     Margin="Margin.Dense"
                                     Disabled="Model.CoinMintType == CoinMintType.Banking"
                                     T="decimal"
                                     @bind-Value="Model.Fineness"
                                     HideSpinButtons="true"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudDatePicker OpenTo="OpenTo.Year"
                                   FixMonth="1" FixDay="1"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   MinDate="@(GetMinDate())"
                                   MaxDate="@(GetMaxDate())"
                                   RelativeWidth="DropdownWidth.Relative"
                                   ShowToolbar="false"
                                   DateFormat="yyyy"
                                   dir="ltr"
                                   Label="@Model.GetDisplayName(() => Model.MintYear)"
                                   @bind-Date="Model.MintYear" />
                </MudItem>
                @if (InvoiceType is InvoiceType.Sell)
                {
                    <MudItem xs="12" md="6" lg="4">
                        <MudNumericField T="decimal"
                                         @bind-Value="Model.ProfitPercent"
                                         Label="@Model.GetDisplayName(() => Model.ProfitPercent)"
                                         For="() => Model.ProfitPercent"
                                         Adornment="Adornment.End"
                                         AdornmentText="درصد"
                                         dir="ltr"
                                         HideSpinButtons="true"
                                         Format="G29"
                                         Immediate="true"
                                         Margin="Margin.Dense"
                                         Variant="Variant.Outlined"
                                         InputMode="InputMode.numeric" />
                    </MudItem>
                }
            </MudGrid>
            @if (Model.CoinPackageType is CoinPackageType.VacuumSealed && Model.CoinPackage is not null)
            {
                <MudText Typo="Typo.body1" Class="mt-4">بسته بندی سکه</MudText>
                <MudDivider />
                <MudGrid Spacing="4">
                    <MudItem xs="12" sm="6" md="4">
                        <MudNumericField Adornment="Adornment.End"
                                         AdornmentText="@GoldUnitType.Gram.GetDisplayName()"
                                         For="() => Model.CoinPackage.VacuumedWeight"
                                         dir="ltr"
                                         Format="G29"
                                         Immediate="true"
                                         HideSpinButtons="true"
                                         Margin="Margin.Dense"
                                         Label="@(Model.GetDisplayName(() => Model.CoinPackage.VacuumedWeight))"
                                         T="decimal?"
                                         @bind-Value="Model.CoinPackage.VacuumedWeight"
                                         Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudTextField @bind-Value="Model.CoinPackage.SerialNumber"
                                      For="() => Model.CoinPackage.SerialNumber!"
                                      Label="@Model.GetDisplayName(() => Model.CoinPackage.SerialNumber)"
                                      Margin="Margin.Dense"
                                      dir="ltr"
                                      T="string"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <div class="d-flex flex-row align-center gap-2">
                            <MudAutocomplete T="CustomerVm"  
                                             @bind-Value="Model.CoinPackage.Issuer"
                                             Text="@(Model.CoinPackage.Issuer != null ? $"{Model.CoinPackage.Issuer.FullName} ({Model.CoinPackage.Issuer.NationalId})" : null)"
                                             For="@(() => Model.CoinPackage.Issuer!)"  
                                             Placeholder="جستجوی کارگاه..."  
                                             Label="@(Model.GetDisplayName(() => Model.CoinPackage.Issuer))"  
                                             ToStringFunc="@(issuer => issuer != null ? $"{issuer.FullName} ({issuer.NationalId})" : null)"  
                                             Margin="Margin.Dense"  
                                             Adornment="Adornment.Start"  
                                             AdornmentIcon="@Icons.Material.Filled.Search"  
                                             Variant="Variant.Outlined"  
                                             SearchFunc="@SearchCustomers"  
                                             ResetValueOnEmptyText="true"  
                                             DebounceInterval="0"  
                                             ShowProgressIndicator="false">  
                            </MudAutocomplete>
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Variant="Variant.Outlined" Color="Color.Primary" OnClick="OnAddCustomer" />
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <div class="d-flex flex-row align-center gap-2">
                            <MudColorPicker @bind-Text="Model.CoinPackage.CardColor"
                                            @ref="_colorPicker"
                                            Label="@Model.GetDisplayName(() => Model.CoinPackage.CardColor)"
                                            ColorPickerView="ColorPickerView.Palette"
                                            TransformOrigin="Origin.TopRight"
                                            AnchorOrigin="Origin.BottomCenter"
                                            Variant="Variant.Outlined"
                                            Margin="Margin.Dense"
                                            Elevation="24" />

                            @if (!string.IsNullOrEmpty(Model.CoinPackage.CardColor))
                            {
                                <div style="width: 30px; height: 30px; border-radius: 16px; border: 1px solid #ccc; background: @Model.CoinPackage.CardColor; cursor: pointer;"  
                                     @onclick="OpenColorPicker">  
                                </div>  
                            }
                        </div>
                    </MudItem>
                </MudGrid>
            }
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Error"
                       OnClick="Close"
                       StartIcon="@Icons.Material.Filled.Close"
                       Variant="Variant.Filled">انصراف</MudButton>

            <MudButton Class="m-2"
                       Color="Color.Primary"
                       Disabled="@_isProcessing"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="@(async () => await Submit())"
                       Variant="Variant.Filled">
                @if (_isProcessing)
                {
                    <MudProgressCircular Class="ms-n1"
                                         Size="Size.Small"
                                         Indeterminate="true" />
                    <MudText Class="ms-2">
                        در حال ذخیره
                    </MudText>
                }
                else
                {
                    <MudText>ذخیره</MudText>
                }
            </MudButton>
        </DialogActions>
    </MudDialog>
</MudForm>