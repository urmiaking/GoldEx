@inherits GoldExComponentBase

@attribute [Route(ClientRoutes.Invoices.SetInvoice)]
@attribute [Route(ClientRoutes.Invoices.Create)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

<PageTitle>@(IdValue.HasValue ? "ویرایش فاکتور" : "فاکتور جدید")</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="px-0" Items="_breadcrumbs" MaxItems="2">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>

    <EditorForm Id="@IdValue" CustomerId="@CustomerId" Barcode="@Barcode" TradeScale="@TradeScaleValue" InvoiceType="@InvoiceTypeValue" />

</MudContainer>