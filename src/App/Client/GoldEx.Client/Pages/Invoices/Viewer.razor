@inherits GoldExComponentBase
@attribute [Route(ClientRoutes.Invoices.ViewInvoice)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

<PageTitle>مشاهده فاکتور</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="px-0" Items="_breadcrumbs" MaxItems="2">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>

    <DxWasmDocumentViewer ReportName="@_reportUrl" Height="1000px" Width="100%">
        <DxDocumentViewerExportSettings UseSameTab=true>
        </DxDocumentViewerExportSettings>
        <DxWasmDocumentViewerRequestOptions InvokeAction="DXXRDV">
        </DxWasmDocumentViewerRequestOptions>
        <DxReportDesignerModelSettings AllowMDI=true>
            <DxReportDesignerWizardSettings UseFullscreenWizard=true />
        </DxReportDesignerModelSettings>
        <DxDocumentViewerCallbacks BeforeRender="reportingCustomization.onBeforeRender" />
    </DxWasmDocumentViewer>
</MudContainer>

<script src="/js/reporting-customization.js?v=1.0.0"></script>