@using GoldEx.Shared.DTOs.PriceUnits
@inherits GoldExComponentBase

<MudForm Model="Model" @ref="@_form" Validation="@(_financialAccountValidator.ValidateValue)" ValidationDelay="0">
    <MudDialog>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudGrid Justify="Justify.Center" Class="align-center">
                        <MudItem xs="12" sm="3">
                            <MudText>نوع حساب:</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="9">
                            <MudRadioGroup T="FinancialAccountType" Required="true" For="() => Model.FinancialAccountType" Value="Model.FinancialAccountType"
                                           ValueChanged="OnAccountTypeChanged">
                                <MudGrid Spacing="0">
                                    <MudItem xs="12" sm="6">
                                        <MudRadio Value="@(FinancialAccountType.LocalBankAccount)">@FinancialAccountType.LocalBankAccount.GetDisplayName()</MudRadio>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudRadio Value="@(FinancialAccountType.InternationalBankAccount)">@FinancialAccountType.InternationalBankAccount.GetDisplayName()</MudRadio>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudRadio Value="@(FinancialAccountType.Cash)">@FinancialAccountType.Cash.GetDisplayName()</MudRadio>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudRadio Value="@(FinancialAccountType.Gold)">@FinancialAccountType.Gold.GetDisplayName()</MudRadio>
                                    </MudItem>
                                </MudGrid>
                            </MudRadioGroup>
                        </MudItem>
                    </MudGrid>
                </MudItem>
                @if (Model.FinancialAccountType != FinancialAccountType.Gold)
                {
                    <MudItem xs="12" md="@(Model.FinancialAccountType is FinancialAccountType.Cash ? 12 : 6)">
                        <MudSelect T="GetPriceUnitTitleResponse?"
                                   @bind-Value="Model.PriceUnit"
                                   Label="@Model.GetDisplayName(() => Model.PriceUnit)"
                                   For="() => Model.PriceUnit"
                                   FitContent="true"
                                   FullWidth="true"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined">
                            @foreach (var item in PriceUnits)
                            {
                                <MudSelectItem Value="item">
                                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                        <MudAvatar Size="Size.Small">
                                            <MudImage Src="@(ApiUrls.Icons.Get(IconType.PriceUnit, item.Id))" Alt="@item.Title" />
                                        </MudAvatar>
                                        <MudText Class="d-none d-md-inline">@item.Title</MudText>
                                    </MudStack>
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                
                @if(Model.CashAccount?.AccountType != CashAccountType.Internal && Model.FinancialAccountType != FinancialAccountType.Gold)
                {
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="Model.BrokerName"
                                      For="@(() => Model.BrokerName)"
                                      Label="@(Model.GetDisplayName(() => Model.BrokerName))"
                                      Margin="Margin.Dense"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="Model.HolderName"
                                      For="@(() => Model.HolderName)"
                                      Label="@(Model.GetDisplayName(() => Model.HolderName))"
                                      Margin="Margin.Dense"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                }

                @switch (Model.FinancialAccountType)
                {
                    case FinancialAccountType.LocalBankAccount when Model.LocalBankAccount != null:
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="Model.LocalBankAccount.AccountNumber"
                                          For="@(() => Model.LocalBankAccount.AccountNumber)"
                                          Label="@(Model.GetDisplayName(() => Model.LocalBankAccount.AccountNumber))"
                                          Margin="Margin.Dense"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="Model.LocalBankAccount.CardNumber"
                                          For="@(() => Model.LocalBankAccount.CardNumber)"
                                          Label="@(Model.GetDisplayName(() => Model.LocalBankAccount.CardNumber))"
                                          Margin="Margin.Dense"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="Model.LocalBankAccount.ShabaNumber"
                                          For="@(() => Model.LocalBankAccount.ShabaNumber)"
                                          Label="@(Model.GetDisplayName(() => Model.LocalBankAccount.ShabaNumber))"
                                          Margin="Margin.Dense"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        break;
                    case FinancialAccountType.InternationalBankAccount when Model.InternationalBankAccount != null:
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="Model.InternationalBankAccount.AccountNumber"
                                          For="@(() => Model.InternationalBankAccount.AccountNumber)"
                                          Label="@(Model.GetDisplayName(() => Model.InternationalBankAccount.AccountNumber))"
                                          Margin="Margin.Dense"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="Model.InternationalBankAccount.SwiftBicCode"
                                          For="@(() => Model.InternationalBankAccount.SwiftBicCode)"
                                          Label="@(Model.GetDisplayName(() => Model.InternationalBankAccount.SwiftBicCode))"
                                          Margin="Margin.Dense"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="Model.InternationalBankAccount.IbanNumber"
                                          For="@(() => Model.InternationalBankAccount.IbanNumber)"
                                          Label="@(Model.GetDisplayName(() => Model.InternationalBankAccount.IbanNumber))"
                                          Margin="Margin.Dense"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        break;
                    case FinancialAccountType.Cash when Model.CashAccount != null:
                        <MudItem xs="12">
                            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText>نوع حساب نقدی:</MudText>
                                <MudRadioGroup T="CashAccountType" Required="true" For="() => Model.CashAccount.AccountType"
                                               Value="Model.CashAccount.AccountType" ValueChanged="OnCashAccountTypeChanged">
                                    <MudRadio Value="@(CashAccountType.Internal)">@CashAccountType.Internal.GetDisplayName()</MudRadio>
                                    <MudRadio Value="@(CashAccountType.DepositsWithOthers)">@CashAccountType.DepositsWithOthers.GetDisplayName()</MudRadio>
                                </MudRadioGroup>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="Model.CashAccount.Title"
                                          For="@(() => Model.CashAccount.Title)"
                                          Label="@(Model.GetDisplayName(() => Model.CashAccount.Title))"
                                          Margin="Margin.Dense"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        break;
                    case FinancialAccountType.Gold:
                    {
                        break;
                    }
                }
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Error"
                       OnClick="Close"
                       StartIcon="@Icons.Material.Filled.Close"
                       Variant="Variant.Filled">بستن</MudButton>
            <MudButton Class="m-2"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="@(() => Submit())"
                       Variant="Variant.Filled">
                <MudText>ذخیره</MudText>
            </MudButton>
        </DialogActions>
    </MudDialog>
</MudForm>