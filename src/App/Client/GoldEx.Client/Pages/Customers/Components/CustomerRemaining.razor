@inherits GoldExComponentBase

<div class="customer-remaining-container">
    @if (_isLoading)
    {
        <MudSkeleton Animation="Animation.Wave"
                     SkeletonType="SkeletonType.Rectangle"
                     Height="32px"
                     Width="120px"
                     Class="rounded" />
    }
    else if (_remainingList?.Any() == true)
    {
        <div class="remaining-carousel">
            <div class="remaining-item-container"
                 style="transform: translateY(-@(_currentIndex * 100)%);
                            transition: transform 0.5s ease-in-out;">
                @foreach (var customerRemaining in _remainingList)
                {
                    <div class="@($"remaining-item {ItemClass}")"
                         @onclick="OnManualSlide"
                         style="@GetClickableStyle()">
                        <MudText Typo="TextTypo"
                                 Color="@GetMudColor(customerRemaining.Amount)">
                            @GetFormattedAmount(customerRemaining)
                        </MudText>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="@($"remaining-item {ItemClass}")">
            <MudText Typo="TextTypo">بدون تراکنش</MudText>
        </div>
    }
</div>
