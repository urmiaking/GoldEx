@using System.Globalization
@inherits GoldExComponentBase

@if (ShowTitle)
{
    <div class="d-flex justify-content-center">
        <MudText Typo="Typo.h5" GutterBottom="true" Class="mt-6">لیست مشتریان</MudText>
    </div>
    <MudDivider />
}

<MudTable T="CustomerVm" Class="@Class" RowsPerPage="14" Hover="true" @ref="_table" FixedHeader="true" ContainerClass="@ContainerClass"
          Dense="true" ServerData="LoadCustomersAsync" SelectOnRowClick="false" Breakpoint="Breakpoint.Sm" Elevation="@Elevation">
    <ToolBarContent>
        <MudTextField T="string" Clearable="true" Immediate="true" DebounceInterval="500" ValueChanged="@(s => OnSearch(s))"
                      Placeholder="جستجو ..." Adornment="Adornment.Start" Variant="Variant.Outlined" Margin="Margin.Dense"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"></MudTextField>
        <MudSpacer />

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudDateRangePicker DateRange="@_filterDateRange"
                                DateRangeChanged="OnDateRangeChanged"
                                Margin="Margin.Dense"
                                Variant="Variant.Outlined"
                                Class="ml-3"
                                MaxMonthColumns="1"
                                DisplayMonths="1"
                                Rounded="true"
                                ShowToolbar="false"
                                Style="max-width: 320px;"
                                PlaceholderStart="از"
                                PlaceholderEnd="تا"
                                Label="تاریخ ثبت مشتری"
                                Clearable="true" />

            <MudButtonGroup Size="Size.Small" Color="@TransactionTypeColor" Variant="Variant.Filled" Class="ml-3">
                <MudButton Size="Size.Small" StartIcon="@TransactionTypeIcon">
                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                        @(_transactionType?.GetDisplayName() ?? "وضعیت حساب")
                    </MudHidden>
                </MudButton>

                <MudMenu Size="Size.Small"
                         Icon="@Icons.Material.Filled.ArrowDropDown"
                         Style="align-self: auto;">
                    <MudMenuItem OnClick="() => SetTransactionTypeFilterText(null)">
                        <MudIcon Icon="@GetTransactionTypeIcon(null)" Color="@GetTransactionTypeIconColor(null)" Class="mr-2" />
                        بدهکار / بستانکار
                    </MudMenuItem>

                    @foreach (var type in Enum.GetValues<TransactionType>())
                    {
                        <MudMenuItem OnClick="() => SetTransactionTypeFilterText(type)">
                            <MudIcon Icon="@GetTransactionTypeIcon(type)" Color="@GetTransactionTypeIconColor(type)" Class="mr-2" />
                            فقط @type.GetDisplayName()
                        </MudMenuItem>
                    }

                </MudMenu>
            </MudButtonGroup>

            <MudButtonGroup Size="Size.Small" Color="@CustomerTypeColor" Variant="Variant.Filled" Class="ml-3">
                <MudButton Size="Size.Small" StartIcon="@CustomerTypeIcon">
                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                        @(_customerType?.GetDisplayName() ?? "نوع مشتری")
                    </MudHidden>
                </MudButton>

                <MudMenu Size="Size.Small"
                         Icon="@Icons.Material.Filled.ArrowDropDown"
                         Style="align-self: auto;">
                    <MudMenuItem OnClick="() => SetCustomerTypeFilterText(null)">
                        <MudIcon Icon="@GetCustomerTypeIcon(null)" Color="@GetCustomerTypeIconColor(null)" Class="mr-2" />
                        همه
                    </MudMenuItem>

                    @foreach (var type in Enum.GetValues<CustomerType>())
                    {
                        <MudMenuItem OnClick="() => SetCustomerTypeFilterText(type)">
                            <MudIcon Icon="@GetCustomerTypeIcon(type)" Color="@GetCustomerTypeIconColor(type)" Class="mr-2" />
                            @type.GetDisplayName()
                        </MudMenuItem>
                    }

                </MudMenu>
            </MudButtonGroup>

            <MudButton Class="ml-4" Color="Color.Primary" EndIcon="@Icons.Material.Filled.Add" OnClick="@(_ => OnCreate())" Size="Size.Small" Variant="Variant.Filled">ثبت مشتری جدید</MudButton>
        </MudHidden>

        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Tune"
                           Color="Color.Success"
                           Variant="Variant.Filled"
                           Class="mr-3"
                           Size="Size.Small"
                           OnClick="OpenMobileFilters" />

            <MudIconButton Color="@Color.Primary"
                           Icon="@Icons.Material.Filled.Add"
                           Class="mr-3" OnClick="@(_ => OnCreate())"
                           Size="@Size.Small" Variant="@Variant.Filled"/>
        </MudHidden>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortLabel="FullName" T="CustomerVm">نام مشتری</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortLabel="CustomerType" T="CustomerVm">نوع</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortLabel="NationalId" T="CustomerVm">کد مشتری</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortLabel="PhoneNumber" T="CustomerVm">شماره تماس</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortLabel="CreatedAt" T="CustomerVm">تاریخ ثبت</MudTableSortLabel></MudTh>
        <MudTh>مانده</MudTh>
        <MudTh>عملیات</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="نام مشتری">@context.FullName</MudTd>
        <MudTd DataLabel="نوع">@context.CustomerType.GetDisplayName()</MudTd>
        <MudTd DataLabel="کد مشتری">@context.NationalId</MudTd>
        <MudTd DataLabel="شماره تماس">@context.PhoneNumber</MudTd>
        <MudTd DataLabel="تاریخ ثبت">
            <MudTooltip Text="@context.CreatedAt.ToString(CultureInfo.CurrentUICulture)" Placement="Placement.Top" Arrow="true">
                @context.CreatedAt.ToShortDateString()
            </MudTooltip>
        </MudTd>
        <MudTd DataLabel="مانده">
            <CustomerRemaining CustomerId="@context.Id!.Value" EnableManualSlide="true" ItemClass="justify-content-end justify-content-lg-start" />
        </MudTd>
        <MudTd DataLabel="عملیات">
            <div class="d-flex gap-2">
                <MudTooltip Text="مشاهده تراکنش های مشتری">
                    <MudIconButton Icon="@Icons.Material.Filled.DocumentScanner" Size="Size.Small" Variant="Variant.Filled"
                                   Color="Color.Success" OnClick="_ => OnViewTransaction(context)"></MudIconButton>
                </MudTooltip>
                <MudTooltip Text="مشاهده فاکتورهای مشتری">
                    <MudIconButton Icon="@Icons.Material.Filled.LibraryBooks" Size="Size.Small" Variant="Variant.Filled"
                                   Color="Color.Info" OnClick="_ => OnViewInvoices(context)"></MudIconButton>
                </MudTooltip>
                <MudTooltip Text="ویرایش">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Filled"
                                   Color="Color.Primary" OnClick="_ => OnEdit(context)"></MudIconButton>
                </MudTooltip>
                <MudTooltip Text="حذف">
                    <MudIconButton OnClick="@(_ => OnRemove(context))" Size="@Size.Small" Variant="@Variant.Filled"
                                   Icon="@Icons.Material.Filled.Delete" Color="@Color.Error"></MudIconButton>
                </MudTooltip>
            </div>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>هیچ مشتری یافت نشد</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>در حال بارگیری</MudText>
    </LoadingContent>
    <PagerContent>
        @{
            var totalItems = _table.GetFilteredItemsCount();
            var startItem = totalItems == 0 ? 0 : _table.CurrentPage * _table.RowsPerPage + 1;
            var endItem = Math.Min((_table.CurrentPage + 1) * _table.RowsPerPage, totalItems);
            var pageCount = (totalItems + _table.RowsPerPage - 1) / _table.RowsPerPage;
            var infoText = $"نمایش {startItem} تا {endItem} از {totalItems} ردیف";
        }

        <div class="d-flex flex-column flex-sm-row align-center justify-sm-space-between w-100 pa-4" style="gap: 1rem;">
            <div class="mud-table-pagination-caption">
                @infoText
            </div>
            <MudPagination SelectedChanged="PageChanged"
                           Color="Color.Primary"
                           Count="@pageCount"
                           Class="justify-center"
                           BoundaryCount="1"
                           MiddleCount="3" />

            <div class="d-none d-sm-block mud-table-pagination-caption" style="visibility: hidden; pointer-events: none;">
                @infoText
            </div>
        </div>
    </PagerContent>
</MudTable>