@attribute [Route(ClientRoutes.InventoryStocks.List)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]
@inherits GoldExComponentBase

<PageTitle>لیست موجودی</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="px-0" Items="_breadcrumbs" MaxItems="2">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>
    
    <MudText Typo="Typo.h5" GutterBottom="true" Class="text-center d-md-block d-none">لیست موجودی انبار</MudText>
    <MudDivider Class="mb-2 d-md-block d-none" />

    <InventoryStockList Class="mb-4" ContainerClass="responsive-table-toolbar" SearchQuery="@SearchQuery" PersistState="true" />

</MudContainer>