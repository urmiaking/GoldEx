@attribute [Route(ClientRoutes.InventoryStocks.MeltingBatches.Index)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

@inherits GoldExComponentBase

<PageTitle>ذوب طلا</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="px-0" Items="_breadcrumbs" MaxItems="2">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>

    <MudText Typo="Typo.h5" GutterBottom="true" Class="text-center d-md-block d-none">لیست ذوب طلا</MudText>
    <MudDivider Class="mb-2 d-md-block d-none" />

    <MeltingBatchesList Class="mb-4" Elevation="24" ContainerClass="responsive-table-toolbar" SearchQuery="@SearchQuery" />

</MudContainer>