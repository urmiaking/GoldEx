@using GoldEx.Client.Pages.Settings.ViewModels

<MudOverlay Visible="@Open"
            DarkBackground="true">
    <MudPopover Open="Open"
                Class="pa-3 responsive-popover"
                Fixed="true"
                AnchorOrigin="Origin.CenterCenter"
                TransformOrigin="Origin.CenterCenter"
                Elevation="6">
        <MudStack Spacing="2" Class="w-100">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.subtitle1">فیلترها</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="OnClose" />
            </MudStack>

            <!-- Item Type -->
            <MudSelect T="ItemType"
                       Variant="Variant.Outlined"
                       Label="نوع آیتم"
                       Value="@_itemType"
                       ValueChanged="OnItemTypeChanged"
                       Dense="true"
                       Margin="Margin.Dense"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@GetItemTypeIcon(_itemType)"
                       AdornmentColor="@GetItemTypeIconColor(_itemType)"
                       Class="w-100">
                @foreach (var type in _selectableTypes)
                {
                    <MudSelectItem Value="@type">
                        @type.GetDisplayName()
                    </MudSelectItem>
                }
            </MudSelect>

            <!-- Item Status -->
            <MudSelect T="ItemStatus"
                       Variant="Variant.Outlined"
                       Label="وضعیت"
                       Value="@_itemStatus"
                       ValueChanged="@(v => _itemStatus = v)"
                       Dense="true"
                       Margin="Margin.Dense"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@GetStatusIcon(_itemStatus)"
                       AdornmentColor="@GetStatusColor(_itemStatus)"
                       Class="w-100">
                <MudSelectItem Value="@ItemStatus.Available">@ItemStatus.Available.GetDisplayName()</MudSelectItem>

                @if (_itemType is not ItemType.UsedProduct)
                {
                    <MudSelectItem Value="@ItemStatus.Sold">@ItemStatus.Sold.GetDisplayName()</MudSelectItem>
                }

                @if (_itemType is ItemType.UsedProduct)
                {
                    <MudSelectItem Value="@ItemStatus.Melted">@ItemStatus.Melted.GetDisplayName()</MudSelectItem>
                }
            </MudSelect>

            <!-- Category (only for Product) -->
            @if (_itemType is ItemType.Product)
            {
                <MudSelect T="ProductCategoryVm"
                           Variant="Variant.Outlined"
                           Label="دسته‌بندی"
                           Value="@_categoryFilter"
                           ValueChanged="@(v => _categoryFilter = v)"
                           Dense="true"
                           Margin="Margin.Dense"
                           Adornment="Adornment.Start"
                           AdornmentIcon="@Icons.Material.Filled.List"
                           AdornmentColor="@(_categoryFilter is null ? Color.Info : Color.Success)"
                           Class="w-100">
                    <MudSelectItem Value="@(null as ProductCategoryVm)">همه دسته‌بندی‌ها</MudSelectItem>
                    @foreach (var cat in Categories)
                    {
                        <MudSelectItem Value="@cat">@cat.Title</MudSelectItem>
                    }
                </MudSelect>
            }

            <!-- Date range -->
            <MudDateRangePicker DateRange="@_dateRange"
                                DateRangeChanged="@(dr => _dateRange = dr)"
                                Variant="Variant.Outlined"
                                Label="@DateRangeLabel"
                                Margin="Margin.Dense"
                                MaxMonthColumns="1"
                                DisplayMonths="1"
                                Adornment="Adornment.Start"
                                ShowToolbar="false"
                                Clearable="true"
                                Class="w-100" />

            <!-- Actions -->
            <MudStack Row="true" Spacing="1" Class="mt-3" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="Clear" StartIcon="@Icons.Material.Filled.Delete">حذف فیلترها</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Apply" StartIcon="@Icons.Material.Filled.Check">اعمال</MudButton>
            </MudStack>
        </MudStack>
    </MudPopover>
</MudOverlay>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    [Parameter] public ItemType ItemType { get; set; }
    [Parameter] public ItemStatus ItemStatus { get; set; }
    [Parameter] public ProductCategoryVm? CategoryFilter { get; set; }
    [Parameter] public List<ProductCategoryVm> Categories { get; set; } = new();
    [Parameter] public DateRange DateRange { get; set; } = new();
    [Parameter] public bool Selectable { get; set; }

    [Parameter] public EventCallback<InventoryStockList.MobileFiltersResult> OnApply { get; set; }

    private ItemType _itemType;
    private ItemStatus _itemStatus;
    private ProductCategoryVm? _categoryFilter;
    private DateRange _dateRange = new();

    private readonly ItemType[] _selectableTypes = Enum.GetValues<ItemType>();

    private string DateRangeLabel => ItemStatus switch
    {
        ItemStatus.Available => "تاریخ ثبت جنس",
        ItemStatus.Sold => "تاریخ فروش جنس",
        ItemStatus.Melted => "تاریخ ذوب جنس",
        _ => "تاریخ"
    };

    protected override void OnParametersSet()
    {
        _itemType = ItemType;
        _itemStatus = ItemStatus;
        _categoryFilter = CategoryFilter;
        _dateRange = new DateRange(DateRange.Start, DateRange.End);
    }

    private void OnItemTypeChanged(ItemType newType)
    {
        _itemType = newType;

        if (_itemType is not ItemType.UsedProduct && _itemStatus == ItemStatus.Melted)
        {
            _itemStatus = ItemStatus.Available;
        }
    }

    private string GetItemTypeIcon(ItemType type) => type switch
    {
        ItemType.Product => Icons.Material.Filled.Diamond,
        ItemType.MoltenGold => Icons.Material.Filled.Whatshot,
        ItemType.UsedProduct => Icons.Material.Filled.DiscFull,
        ItemType.Coin => Icons.Material.Filled.MonetizationOn,
        ItemType.Currency => Icons.Material.Filled.AttachMoney,
        _ => Icons.Material.Filled.Help
    };

    private Color GetItemTypeIconColor(ItemType type) => type switch
    {
        ItemType.Product => Color.Info,
        ItemType.MoltenGold => Color.Warning,
        ItemType.UsedProduct => Color.Error,
        ItemType.Coin => Color.Primary,
        ItemType.Currency => Color.Tertiary,
        _ => Color.Default
    };

    private string GetStatusIcon(ItemStatus status) => status switch
    {
        ItemStatus.Available => Icons.Material.Filled.Warehouse,
        ItemStatus.Sold => Icons.Material.Filled.ShoppingBasket,
        ItemStatus.Melted => Icons.Material.Filled.Whatshot,
        _ => Icons.Material.Filled.Help
    };

    private Color GetStatusColor(ItemStatus status) => status switch
    {
        ItemStatus.Available => Color.Success,
        ItemStatus.Sold => Color.Error,
        ItemStatus.Melted => Color.Warning,
        _ => Color.Default
    };

    private async Task Apply()
    {
        var result = new InventoryStockList.MobileFiltersResult(
            _itemType,
            _itemStatus,
            _itemType is ItemType.Product ? _categoryFilter : null,
            new DateRange(_dateRange.Start, _dateRange.End)
        );
        await OnApply.InvokeAsync(result);
    }

    private async Task Clear()
    {
        _itemType = ItemType.Product;
        _itemStatus = ItemStatus.Available;
        _categoryFilter = null;
        _dateRange = new DateRange();
        await Apply();
    }
}