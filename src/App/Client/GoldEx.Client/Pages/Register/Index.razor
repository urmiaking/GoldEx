@attribute [Route(ClientRoutes.RegisterProduct.Index)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

@inherits GoldExComponentBase

<PageTitle>فعالسازی نرم افزار</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="mb-6">
        <MudAvatar Size="Size.Large" Color="Color.Primary">
            <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Large" />
        </MudAvatar>

        <MudText Typo="Typo.h4" Align="Align.Center" Color="Color.Primary">
            فعال ‌سازی نرم‌ افزار <span class="brand-text fs-2">GoldEx</span>
        </MudText>

        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Info">
            برای شروع استفاده از نرم ‌افزار، ابتدا محصول را فعال کنید.
            شما می‌توانید بدون پرداخت هزینه، از نسخه پایه استفاده نمایید.
        </MudText>
    </MudStack>
    <MudGrid Spacing="6">
        <MudItem xs="12" md="6">
            <MudCard Elevation="16" Class="h-100 border border-info">
                <MudCardContent>

                    <MudStack Spacing="2" AlignItems="AlignItems.Center">

                        <MudAvatar Size="Size.Large" Color="Color.Info">
                            <MudIcon Icon="@Icons.Material.Filled.HourglassTop" Size="Size.Large" />
                        </MudAvatar>

                        <MudText Typo="Typo.h6">
                            نسخه پایه (رایگان)
                        </MudText>

                        <MudChip Color="Color.Info" Variant="Variant.Filled" T="string">
                            ۳۰ روز استفاده رایگان
                        </MudChip>

                        <MudDivider Class="my-2" />

                        <MudText Typo="Typo.body2" Align="Align.Center">
                            پس از فعال‌سازی، به مدت ۳۰ روز می‌توانید از نرم‌افزار استفاده کنید.
                            پس از پایان دوره آزمایشی، برخی امکانات محدود می‌شوند.
                        </MudText>

                        <MudList Dense="true" T="string" Class="w-100">
                            <MudListItem>
                                <div class="d-flex gap-4">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                    <MudText>ثبت حداکثر ۵ فاکتور در روز</MudText>
                                </div>
                            </MudListItem>

                            <MudListItem>
                                <div class="d-flex gap-4">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                    <MudText>گزارش‌گیری پایه</MudText>
                                </div>
                            </MudListItem>

                            <MudListItem>
                                <div class="d-flex gap-4">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                    <MudText>پشتیبانی از ارز تومان و گرم</MudText>
                                </div>
                            </MudListItem>

                            <MudListItem>
                                <div class="d-flex gap-4">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                    <MudText>ثبت طلا، جواهر، آبشده و سکه</MudText>
                                </div>
                            </MudListItem>
                        </MudList>

                    </MudStack>

                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Elevation="20" Class="h-100 border border-warning">
                <MudCardContent>

                    <MudStack Spacing="2" AlignItems="AlignItems.Center">

                        <MudAvatar Size="Size.Large" Color="Color.Primary">
                            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Size="Size.Large" />
                        </MudAvatar>

                        <MudText Typo="Typo.h6">
                            نسخه کامل (Premium)
                        </MudText>

                        <MudChip Color="Color.Primary" Variant="Variant.Filled" T="string">
                            بدون محدودیت
                        </MudChip>

                        <MudDivider Class="my-2" />

                        <MudText Typo="Typo.body2" Align="Align.Center">
                            پس از پایان دوره آزمایشی، می‌توانید با فعال‌سازی نسخه کامل
                            بدون هیچ محدودیتی از نرم‌افزار استفاده کنید.
                        </MudText>

                        <MudList Dense="true" T="string" Class="w-100">
                            <MudListItem>
                                <div class="d-flex gap-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" />
                                    <MudText>ثبت نامحدود فاکتور و پرداخت</MudText>
                                </div>
                            </MudListItem>

                            <MudListItem>
                                <div class="d-flex gap-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" />
                                    <MudText>گزارش‌گیری کامل و پیشرفته</MudText>
                                </div>
                            </MudListItem>

                            <MudListItem>
                                <div class="d-flex gap-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" />
                                    <MudText>حسابداری چند ارزی</MudText>
                                </div>
                            </MudListItem>

                            <MudListItem>
                                <div class="d-flex gap-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" />
                                    <MudText>امکان ثبت طلای مستعمل و انواع ارز</MudText>
                                </div>
                            </MudListItem>
                        </MudList>

                    </MudStack>

                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
    <MudPaper Class="mt-8 pa-6 text-center" Elevation="8">

        <MudText Typo="Typo.body1" Class="mb-3">
            برای شروع، اطلاعات مجموعه خود را ثبت کنید.
            کد فعال‌ سازی به شماره موبایل شما ارسال خواهد شد.
        </MudText>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Login"
                   OnClick="GoToRegisterForm">
            شروع فرآیند فعال ‌سازی
        </MudButton>

    </MudPaper>

</MudContainer>