@inherits GoldExComponentBase

<MudPaper Class="@Class" Elevation="24">
    
    <!-- Overlay for Progress -->
    <MudOverlay Visible="@_processing" DarkBackground="true" Absolute="true" ZIndex="200">
        <MudPaper Elevation="4" Class="pa-6 d-flex flex-column align-center justify-center gap-2"
                  Width="320px" Style="border-radius: 20px; background: var(--mud-palette-surface);">

            <!-- Animated Icon -->
            <div class="pulse-icon mb-2">
                <MudIcon Icon="@Icons.Material.Filled.CloudSync"
                         Color="Color.Primary"
                         Style="width: 64px; height: 64px;" />
            </div>

            <!-- Main Title -->
            <MudText Typo="Typo.h6" Align="Align.Center" Color="Color.Primary">
                <b>در حال ذخیره سازی</b>
            </MudText>

            <!-- Dynamic Status Message -->
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary mb-2" Style="height: 20px;">
                @_progressMessage
            </MudText>

            <!-- Progress Bar Section -->
            <div class="w-100">
                <MudProgressLinear Color="Color.Info"
                                   Value="@_currentItemCount"
                                   Max="@_totalItems"
                                   Rounded="true"
                                   Size="Size.Large"
                                   Striped="true"
                                   Class="my-1" />

                <!-- Details Row -->
                <div class="d-flex justify-space-between px-1 mt-1">
                    <MudText Typo="Typo.caption" Color="Color.Default">
                        آیتم @_currentItemCount از @_totalItems
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Primary">
                        <b>@GetPercentage()%</b>
                    </MudText>
                </div>
            </div>
        </MudPaper>
    </MudOverlay>


    <MudTabs Elevation="2" Rounded="true" Centered="true">
        <MudTabPanel Text="طلا، جواهر و آبشده" Icon="@Icons.Material.Filled.Diamond" IconColor="Color.Info">
            <ProductList PriceUnit="_priceUnit" Model="_model" GramPriceChanged="OnGramPriceChanged"/>
        </MudTabPanel>
        <MudTabPanel Text="سکه" Icon="@Icons.Material.Filled.MonetizationOn" IconColor="Color.Primary">
            <CoinList PriceUnit="_priceUnit" Model="_model"/>
        </MudTabPanel>
        <MudTabPanel Text="ارز" Icon="@Icons.Material.Filled.AttachMoney" IconColor="Color.Success">
            <CurrencyList PriceUnit="_priceUnit" Model="_model"/>
        </MudTabPanel>
    </MudTabs>
    <div class="align-items-end d-flex flex-column p-3">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.CloudUpload"
                   Size="Size.Medium"
                   Disabled="@_processing"
                   OnClick="OnSubmitAsync">
            @if (_processing)
            {
                <MudText Class="ms-2">
                    در حال بارگذاری
                </MudText>
            }
            else
            {
                <MudText>بارگذاری</MudText>
            }
        </MudButton>
    </div>
</MudPaper>

<script src="/js/libs/jsbarcode.all.min.js"></script>
<script src="/js/print.js?v=@_jsVersion"></script>

<style>
    .pulse-icon {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% {
            transform: scale(0.95);
            opacity: 0.7;
        }

        50% {
            transform: scale(1.1);
            opacity: 1;
        }

        100% {
            transform: scale(0.95);
            opacity: 0.7;
        }
    }
</style>