@using BlazorBarcodeScanner.ZXing.JS

<MudPaper Class="pa-4 my-2" Elevation="4" Outlined="true">
    @if (_isLoading)
    {
        <div class="d-flex justify-center align-center flex-column gap-2" style="height: 200px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.caption">درحال آماده سازی دوربین</MudText>
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="d-flex justify-center align-center flex-column gap-2" style="height: 200px;">
            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
            <MudText Color="Color.Error">@_errorMessage</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadAsync">تلاش دوباره</MudButton>
        </div>
    }
    else
    {
        <div style="position: relative; background-color: black;">
            @* The library component *@
            <BlazorBarcodeScanner.ZXing.JS.BarcodeReader Title=""
                                                         StartCameraAutomatically="true"
                                                         ShowStart="false"
                                                         ShowReset="false"
                                                         ShowToggleTorch="false"
                                                         ShowResult="false"
                                                         ShowVideoDeviceList="false"
                                                         StreamHeight="1080"
                                                         StreamWidth="1080"
                                                         OnBarcodeReceived="HandleBarcode"
                                                         OnErrorReceived="HandleError" />

            <div style="position: absolute; bottom: 10px; width: 100%; text-align: center;">
                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="CloseScanner">بستن دوربین</MudButton>
            </div>
        </div>
    }
</MudPaper>

@code {
    [Parameter] public EventCallback<string> OnResult { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _isLoading = true;
    private string? _errorMessage;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _isLoading = false;
                StateHasChanged();
            }
            catch (Exception)
            {
                _errorMessage = "باز شدن دوربین با مشکل مواجه شد";
                _isLoading = false;
                StateHasChanged();
            }
        }

        return base.OnAfterRenderAsync(firstRender);
    }

    private async Task HandleBarcode(BarcodeReceivedEventArgs args)
    {
        if (!string.IsNullOrWhiteSpace(args.BarcodeText))
        {
            await OnResult.InvokeAsync(args.BarcodeText);
        }
    }

    

    private async Task ReloadAsync()
    {
        _errorMessage = null;
        _isLoading = true;
        // Re-trigger render logic
        await Task.Delay(500);
        _isLoading = false;
    }

    private async Task CloseScanner()
    {
        await OnClose.InvokeAsync();
    }


    private void HandleError(ErrorReceivedEventArgs args)
    {
        _errorMessage = args.Message;

        // Common User Friendly translation
        if (_errorMessage.Contains("NotAllowedError") || _errorMessage.Contains("Permission denied"))
        {
            _errorMessage = "Camera permission was denied. Please allow camera access.";
        }
        else if (_errorMessage.Contains("NotFoundError"))
        {
            _errorMessage = "No camera device found.";
        }

        StateHasChanged();
    }

}