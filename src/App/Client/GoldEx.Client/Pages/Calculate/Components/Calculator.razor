@inherits GoldExComponentBase

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="@Class" Gutters="false">
    <AuthorizeView>
        <Authorized>
            <MudTabs Elevation="24" Color="Color.Transparent" Centered="true" TabHeaderClass="mb-5 rounded-5">
                <MudTabPanel Text="محاسبه گر عادی" Icon="@Icons.Material.Outlined.Calculate" IconColor="Color.Info">
                    <SimpleCalculator Class="@Class" Elevation="@Elevation"></SimpleCalculator>
                </MudTabPanel>
                <MudTabPanel Text="محاسبه گر معکوس" Icon="@Icons.Material.Outlined.ShoppingBag" IconColor="Color.Success">
                    <ReverseCalculator Class="@Class" Elevation="@Elevation"></ReverseCalculator>
                </MudTabPanel>
            </MudTabs>
        </Authorized>
        <NotAuthorized>
            <SimpleCalculator Class="@Class" Elevation="@Elevation"></SimpleCalculator>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>