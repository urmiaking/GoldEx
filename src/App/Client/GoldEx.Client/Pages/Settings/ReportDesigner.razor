@attribute [Route(ClientRoutes.Reporting.DesignReport)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

@layout MainLayout

@inherits GoldExComponentBase

<PageTitle>طراحی گزارش @(DisplayName ?? Name)</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="px-0" Items="_breadcrumbs" MaxItems="2">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>

    <div class="d-flex align-center justify-center">
        <MudText Typo="Typo.h5" GutterBottom="true">طراحی گزارش @(DisplayName ?? Name)</MudText>
    </div>
    <MudDivider Class="my-2" />

    <DxWasmReportDesigner ReportName="@Name" Height="850px" Width="100%" DevelopmentMode=true>
        <DxWasmReportDesignerRequestOptions GetDesignerModelAction="DXXRD/GetReportDesignerModel">
        </DxWasmReportDesignerRequestOptions>
        <DxReportDesignerModelSettings AllowMDI=true RightToLeft="true">
            <DxReportDesignerWizardSettings UseFullscreenWizard=true />
        </DxReportDesignerModelSettings>
    </DxWasmReportDesigner>
</MudContainer>