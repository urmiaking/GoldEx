@using GoldEx.Shared.Enums
@inherits GoldExComponentBase

<EditForm Model="Model" OnValidSubmit="Submit">
    <DataAnnotationsValidator />

    <MudDialog>
        <DialogContent>
            <MudGrid>
                <MudItem xs="6">
                    <MudTextField @bind-Value="Model.Title"
                                   For="@(() => Model.Title)"
                                   Label="@Model.GetDisplayName(() => Model.Title)"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="Model.EnTitle"
                                   For="@(() => Model.EnTitle)"
                                   dir="ltr"
                                   Label="@Model.GetDisplayName(() => Model.EnTitle)"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="Model.Symbol"
                                   For="@(() => Model.Symbol)"
                                   dir="ltr"
                                   Label="@Model.GetDisplayName(() => Model.Symbol)"
                                   Margin="Margin.Dense"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudSelect T="StoneKind"
                               Label="@Model.GetDisplayName(() => Model.Kind)"
                               Margin="Margin.Dense"
                               Variant="Variant.Outlined"
                               Disabled="@(Id.HasValue)"
                               @bind-Value="Model.Kind">
                        @foreach (StoneKind kind in Enum.GetValues(typeof(StoneKind)))
                        {
                            <MudSelectItem Value="@kind">@kind.GetDisplayName()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Error"
                       OnClick="Close"
                       StartIcon="@Icons.Material.Filled.Close"
                       Variant="Variant.Filled">انصراف</MudButton>

            <MudButton Class="m-2"
                       Color="Color.Primary"
                       Disabled="@IsBusy"
                       StartIcon="@Icons.Material.Filled.Save"
                       ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled">
                @if (IsBusy)
                {
                    <MudProgressCircular Class="ms-n1"
                                         Size="Size.Small"
                                         Indeterminate="true" />
                    <MudText Class="ms-2">
                        در حال ذخیره
                    </MudText>
                }
                else
                {
                    <MudText>ذخیره</MudText>
                }
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>
