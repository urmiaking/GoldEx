@using GoldEx.Shared.DTOs.Prices
@inherits GoldExComponentBase

<EditForm Model="Model" OnValidSubmit="Submit">
    <DataAnnotationsValidator />

    <MudDialog>
        <DialogContent>
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6" lg="6">
                    <MudTextField @bind-Value="Model.Title"
                                  For="@(() => Model.Title)"
                                  Label="@(Model.GetDisplayName(() => Model.Title))"
                                  Margin="Margin.Dense"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6" lg="6">
                    <MudNumericField @bind-Value="Model.Weight"
                                     For="@(() => Model.Weight)"
                                     Label="@(Model.GetDisplayName(() => Model.Weight))"
                                     Margin="Margin.Dense"
                                     Format="G29"
                                     Adornment="Adornment.End"
                                     AdornmentText="گرم"
                                     dir="ltr"
                                     HideSpinButtons="true"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudDatePicker OpenTo="OpenTo.Year"
                                   FixMonth="1" FixDay="1"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   MaxDate="@(Model.EndMintYear ?? DateTime.Now)"
                                   RelativeWidth="DropdownWidth.Relative"
                                   ShowToolbar="false"
                                   DateFormat="yyyy"
                                   Clearable="true"
                                   dir="ltr"
                                   Label="@Model.GetDisplayName(() => Model.StartMintYear)"
                                   @bind-Date="Model.StartMintYear" />
                </MudItem>

                <MudItem xs="12" sm="6" md="6">
                    <MudDatePicker OpenTo="OpenTo.Year"
                                   FixMonth="1" FixDay="1"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   MinDate="@(Model.StartMintYear)"
                                   MaxDate="@(DateTime.Now)"
                                   RelativeWidth="DropdownWidth.Relative"
                                   ShowToolbar="false"
                                   DateFormat="yyyy"
                                   Clearable="true"
                                   dir="ltr"
                                   Label="@Model.GetDisplayName(() => Model.EndMintYear)"
                                   @bind-Date="Model.EndMintYear" />
                </MudItem>
                <MudItem xs="12" md="6" lg="6">
                    <MudNumericField @bind-Value="Model.Fineness"
                                     For="@(() => Model.Fineness)"
                                     Label="@(Model.GetDisplayName(() => Model.Fineness))"
                                     Margin="Margin.Dense"
                                     Format="G29"
                                     dir="ltr"
                                     HideSpinButtons="true"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6" lg="6">
                    <MudSelect T="GetPriceTitleResponse?"
                               Value="Model.Price"
                               ValueChanged="OnPriceChanged"
                               For="@(() => Model.Price)"
                               Label="@(Model.GetDisplayName(() => Model.PriceId))"
                               Margin="Margin.Dense"
                               Variant="Variant.Outlined">
                        @foreach (var price in _prices)
                        {
                            <MudSelectItem Value="@price">@price.Title</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="12" lg="12">
                    <MudAlert Severity="Severity.Info">هنگام انتخاب این سکه، قیمت وابسته ای که برای آن انتخاب شود در نرخ تبدیل ارزها لحاظ خواهد شد</MudAlert>
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Error"
                       OnClick="Close"
                       StartIcon="@Icons.Material.Filled.Close"
                       Variant="Variant.Filled">انصراف</MudButton>

            <MudButton Class="m-2"
                       Color="Color.Primary"
                       Disabled="@_processing"
                       StartIcon="@Icons.Material.Filled.Save"
                       ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled">
                @if (_processing)
                {
                    <MudProgressCircular Class="ms-n1"
                                         Size="Size.Small"
                                         Indeterminate="true" />
                    <MudText Class="ms-2">
                        در حال ذخیره
                    </MudText>
                }
                else
                {
                    <MudText>ذخیره</MudText>
                }
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>