@inherits GoldExComponentBase

<MudDialog>
    <DialogContent>
        <MudText>آیا از حذف فروشگاه "@StoreName" مطمئن هستید؟</MudText>
        <MudText Color="Color.Error" Typo="Typo.caption" Class="mt-2 d-block">توجه: حذف فیزیکی فقط در صورتی امکان‌پذیر است که هیچ سندی با این فروشگاه ثبت نشده باشد. در غیر این صورت می‌توانید وضعیت را به غیرفعال تغییر دهید.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">لغو</MudButton>
        <MudButton Class="m-3"
                   Color="Color.Error"
                   Disabled="@IsBusy"
                   StartIcon="@Icons.Material.Filled.Delete"
                   OnClick="@(async () => await OnValidSubmit())"
                   Variant="Variant.Filled">
            @if (IsBusy)
            {
                <MudProgressCircular Class="ms-n1"
                                     Size="Size.Small"
                                     Indeterminate="true" />
                <MudText Class="ms-2">در حال حذف</MudText>
            }
            else
            {
                <MudText>حذف</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>
