@inherits GoldExComponentBase

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
<MudCard Elevation="24" Class="rounded-xl overflow-hidden mud-width-full" Style="height: var(--designer-height);">
    <div class="designer-layout-container">
        
        <!-- هدر تب‌ها برای موبایل -->
        <div class="mobile-tabs-header">
            <button type="button" class="mobile-tab-btn @(_activeMobileTab == 0 ? "is-active" : "")" @onclick="() => SetMobileTab(0)">
                <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" Class="me-1" />
                آیتم‌ها
            </button>
            <button type="button" class="mobile-tab-btn @(_activeMobileTab == 1 ? "is-active" : "")" @onclick="() => SetMobileTab(1)">
                <MudIcon Icon="@Icons.Material.Filled.AspectRatio" Size="Size.Small" Class="me-1" />
                بوم طراحی
            </button>
            <button type="button" class="mobile-tab-btn @(_activeMobileTab == 2 ? "is-active" : "")" @onclick="() => SetMobileTab(2)">
                <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Class="me-1" />
                تنظیمات ویژگی‌ها
            </button>
        </div>
        
        <div class="designer-main-body">
    
    <!-- پنل سمت چپ: فهرست و دایرکتوری آیتم‌ها -->
    <div class="designer-panel panel-left border-solid border-l mud-border-default @(GetTabClass(0))">
        <div class="panel-header">
            <MudIcon Icon="@Icons.Material.Filled.Category" Color="Color.Secondary" Class="me-2" />
            <MudText Typo="Typo.h6" Class="panel-title">دایرکتوری آیتم‌های برچسب</MudText>
        </div>
        
        <div class="panel-body">
            <MudAlert Severity="Severity.Normal" Dense="true" Class="mb-4 rounded-lg px-3 py-2 text-xs">
                آیتم‌ها را فعال/غیرفعال کنید و برای پیکربندی دقیق، روی آن‌ها کلیک کنید.
            </MudAlert>

            <!-- دکمه تنظیمات کلی قالب -->
            <button class="global-settings-card mb-4 @(_selectedItem == null ? "is-active" : "")" @onclick="() => SelectItem(null)">
                <div class="d-flex align-center w-full">
                    <div class="icon-wrapper bg-primary-light">
                        <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Size="Size.Medium" />
                    </div>
                    <div class="ms-3 text-start flex-grow-1">
                        <MudText Typo="Typo.subtitle2" Class="font-bold">تنظیمات ابعاد فیزیکی</MudText>
                        <MudText Typo="Typo.caption" Class="text-muted d-block">اندازه کل برچسب، دم اتصال و حاشیه‌ها</MudText>
                    </div>
                    @if (_selectedItem == null)
                    {
                        <div class="active-dot"></div>
                    }
                </div>
            </button>

            <MudDivider Class="my-3" />

            <MudText Typo="Typo.overline" Class="text-muted font-bold d-block mb-2">لیست مؤلفه‌های چاپ</MudText>
            
            <div class="items-list">
                @foreach (BarcodePrintableItem itemType in Enum.GetValues(typeof(BarcodePrintableItem)))
                {
                    var activeItem = GetActiveItem(itemType);
                    var isActive = activeItem != null;
                    var label = itemType switch
                    {
                        BarcodePrintableItem.Barcode => "بارکد کالا",
                        BarcodePrintableItem.ProductName => "عنوان کالا (نام)",
                        BarcodePrintableItem.Weight => "وزن کالا (گرم)",
                        BarcodePrintableItem.Wage => "اجرت کالا (درصد/مبلغ)",
                        _ => "نامشخص"
                    };
                    var icon = itemType switch
                    {
                        BarcodePrintableItem.Barcode => Icons.Material.Filled.QrCode,
                        BarcodePrintableItem.ProductName => Icons.Material.Filled.Label,
                        BarcodePrintableItem.Weight => Icons.Material.Filled.Scale,
                        BarcodePrintableItem.Wage => Icons.Material.Filled.AttachMoney,
                        _ => Icons.Material.Filled.Help
                    };

                    <div class="element-list-item @(activeItem == _selectedItem && _selectedItem != null ? "is-selected" : "")" @onclick="() => { if (isActive) SelectItem(activeItem); }">
                        <div class="d-flex align-center justify-space-between w-full">
                            <div class="d-flex align-center">
                                <div class="icon-avatar @(isActive ? "is-active bg-secondary-light" : "bg-grey-light")">
                                    <MudIcon Icon="@icon" Color="@(isActive ? Color.Secondary : Color.Default)" Size="Size.Small" />
                                </div>
                                <div class="ms-3 text-start">
                                    <MudText Typo="Typo.body2" Class="@(isActive ? "font-bold" : "text-muted")">@label</MudText>
                                    @if (isActive)
                                    {
                                        <span class="active-badge mt-0.5">@GetPositionLabel(activeItem!.Position)</span>
                                    }
                                    else
                                    {
                                        <span class="inactive-badge mt-0.5">غیرفعال</span>
                                    }
                                </div>
                            </div>
                            
                            <MudSwitch T="bool" 
                                       Value="isActive" 
                                       ValueChanged="() => ToggleItemActive(itemType)" 
                                       Color="Color.Success" 
                                       Size="Size.Small" 
                                       Class="ma-0"
                                       @onclick:stopPropagation />
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- پنل وسط: پیش‌نمایش تعاملی و بوم طراحی -->
    <div class="designer-canvas-area @(GetTabClass(1))">
        <div class="canvas-toolbar">
            <div class="d-flex align-center">
                <div class="status-indicator"></div>
                <MudText Typo="Typo.body2" Class="font-bold text-slate-700">بوم طراحی زنده (میلی‌متر)</MudText>
            </div>
            
            <!-- کنترل‌های زوم -->
            <div class="zoom-controls">
                <MudIconButton Icon="@Icons.Material.Filled.Remove" 
                               Size="Size.Small" 
                               OnClick="() => AdjustZoom(-0.2)" 
                               Disabled="_zoomLevel <= 0.6" 
                               Class="zoom-btn" />
                <span class="zoom-text">@((_zoomLevel * 100).ToString("F0"))%</span>
                <MudIconButton Icon="@Icons.Material.Filled.Add" 
                               Size="Size.Small" 
                               OnClick="() => AdjustZoom(0.2)" 
                               Disabled="_zoomLevel >= 4.0" 
                               Class="zoom-btn" />
                <MudIconButton Icon="@Icons.Material.Filled.CropFree" 
                               Size="Size.Small" 
                               OnClick="ResetZoom" 
                               Title="زوم مناسب" 
                               Class="zoom-btn ms-2" />
            </div>
        </div>

        <div class="canvas-workspace">
            <div class="canvas-scroll-container">
                <div class="canvas-scale-wrapper" style="transform: scale(@_zoomLevel.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));">
                    
                    <!-- بدنه فیزیکی تگ دم موشی طلا -->
                    <div class="tag-body" style="width: @($"{_settings.LabelWidth}mm"); height: @($"{_settings.LabelHeight}mm");" dir="ltr">
                        
                        @{
                            var sideWidthMm = _settings.LabelWidth / 2.0;
                        }

                        <!-- بخش چپ برچسب -->
                        <div class="tag-label-side left-side-label" style="width: @($"{sideWidthMm}mm");">
                            
                            <!-- خط چین حاشیه امن چاپ داخلی (پدینگ) -->
                            <div class="safe-print-area" style="top: @($"{_settings.PaddingTop}mm"); bottom: @($"{_settings.PaddingBottom}mm"); left: @($"{_settings.PaddingLeft}mm"); right: @($"{_settings.PaddingRight}mm");">
                                
                                <!-- نیمه بالا (TopLeft) -->
                                <div class="quadrant-area top-quadrant align-right" @onclick="() => SelectItem(null)" @onclick:stopPropagation>
                                    @foreach (var item in _settings.GetItemsForPosition(BarcodePosition.TopLeft))
                                    {
                                        <div class="render-item @(item == _selectedItem ? "is-selected" : "")" 
                                             style="margin-bottom: @($"{item.ItemSpacing}mm"); @(item.ItemType == BarcodePrintableItem.ProductName ? "align-self: stretch; width: 100%;" : "")"
                                             @onclick="() => SelectItem(item)" 
                                             @onclick:stopPropagation>
                                            @RenderTagItem(item)
                                        </div>
                                    }
                                </div>

                                <!-- نیمه پایین (BottomLeft) -->
                                <div class="quadrant-area bottom-quadrant align-right" @onclick="() => SelectItem(null)" @onclick:stopPropagation>
                                    @foreach (var item in _settings.GetItemsForPosition(BarcodePosition.BottomLeft))
                                    {
                                        <div class="render-item @(item == _selectedItem ? "is-selected" : "")" 
                                             style="margin-bottom: @($"{item.ItemSpacing}mm"); @(item.ItemType == BarcodePrintableItem.ProductName ? "align-self: stretch; width: 100%;" : "")"
                                             @onclick="() => SelectItem(item)" 
                                             @onclick:stopPropagation>
                                            @RenderTagItem(item)
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- بخش راست برچسب (کنار بخش چپ) -->
                        <div class="tag-label-side right-side-label" style="width: @($"{sideWidthMm}mm"); left: @($"{sideWidthMm}mm");">
                            
                            <!-- خط چین حاشیه امن چاپ داخلی (پدینگ) -->
                            <div class="safe-print-area" style="top: @($"{_settings.PaddingTop}mm"); bottom: @($"{_settings.PaddingBottom}mm"); left: @($"{_settings.PaddingLeft}mm"); right: @($"{_settings.PaddingRight}mm");">
                                
                                <!-- نیمه بالا (TopRight) -->
                                <div class="quadrant-area top-quadrant align-left" @onclick="() => SelectItem(null)" @onclick:stopPropagation>
                                    @foreach (var item in _settings.GetItemsForPosition(BarcodePosition.TopRight))
                                    {
                                        <div class="render-item @(item == _selectedItem ? "is-selected" : "")" 
                                             style="margin-bottom: @($"{item.ItemSpacing}mm"); @(item.ItemType == BarcodePrintableItem.ProductName ? "align-self: stretch; width: 100%;" : "")"
                                             @onclick="() => SelectItem(item)" 
                                             @onclick:stopPropagation>
                                            @RenderTagItem(item)
                                        </div>
                                    }
                                </div>

                                <!-- نیمه پایین (BottomRight) -->
                                <div class="quadrant-area bottom-quadrant align-left" @onclick="() => SelectItem(null)" @onclick:stopPropagation>
                                    @foreach (var item in _settings.GetItemsForPosition(BarcodePosition.BottomRight))
                                    {
                                        <div class="render-item @(item == _selectedItem ? "is-selected" : "")" 
                                             style="margin-bottom: @($"{item.ItemSpacing}mm"); @(item.ItemType == BarcodePrintableItem.ProductName ? "align-self: stretch; width: 100%;" : "")"
                                             @onclick="() => SelectItem(item)" 
                                             @onclick:stopPropagation>
                                            @RenderTagItem(item)
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- پنل سمت راست: بازرس ویژگی‌ها (Property Inspector) -->
    <div class="designer-panel panel-right border-solid border-r mud-border-default @(GetTabClass(2))">
        @if (_selectedItem == null)
        {
            <!-- تنظیمات کلی قالب -->
            <div class="panel-header bg-slate-50">
                <MudIcon Icon="@Icons.Material.Filled.AspectRatio" Color="Color.Primary" Class="me-2" />
                <MudText Typo="Typo.h6" Class="panel-title text-slate-800">ابعاد کلی قالب برچسب</MudText>
            </div>
            
            <div class="panel-body">
                <MudStack Spacing="4">
                    
                    <div class="dimension-section">
                        <MudText Typo="Typo.subtitle2" Class="section-title">ابعاد فیزیکی (میلی‌متر)</MudText>
                        
                        <div class="mt-3">
                            <div class="d-flex justify-between align-center mb-1">
                                <span class="input-label">عرض کل برچسب (Label Width)</span>
                                <span class="badge-mm">@_settings.LabelWidth mm</span>
                            </div>
                            <MudSlider @bind-Value="_settings.LabelWidth" Min="30.0" Max="120.0" Step="0.5" Color="Color.Primary" Class="py-0" />
                        </div>

                        <div class="mt-3">
                            <div class="d-flex justify-between align-center mb-1">
                                <span class="input-label">ارتفاع برچسب (Label Height)</span>
                                <span class="badge-mm">@_settings.LabelHeight mm</span>
                            </div>
                            <MudSlider @bind-Value="_settings.LabelHeight" Min="5.0" Max="40.0" Step="0.5" Color="Color.Primary" Class="py-0" />
                        </div>

                        <!-- دم اتصال از تنظیمات فیزیکی حذف شد -->
                    </div>

                    <MudDivider />

                    <div class="dimension-section">
                        <div class="d-flex align-center justify-between mb-2">
                            <MudText Typo="Typo.subtitle2" Class="section-title">حاشیه خارجی چاپ (Margins) - mm</MudText>
                        </div>
                        <MudGrid Spacing="2">
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="_settings.MarginTop" Label="بالا" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.0" Max="10.0" Step="0.1" Format="N1" dir="ltr" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="_settings.MarginRight" Label="راست" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.0" Max="10.0" Step="0.1" Format="N1" dir="ltr" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="_settings.MarginBottom" Label="پایین" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.0" Max="10.0" Step="0.1" Format="N1" dir="ltr" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="_settings.MarginLeft" Label="چپ" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.0" Max="10.0" Step="0.1" Format="N1" dir="ltr" />
                            </MudItem>
                        </MudGrid>
                    </div>

                    <MudDivider />

                    <div class="dimension-section">
                        <div class="d-flex align-center justify-between mb-2">
                            <MudText Typo="Typo.subtitle2" Class="section-title">فاصله داخلی امن (Paddings) - mm</MudText>
                        </div>
                        <MudGrid Spacing="2">
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="_settings.PaddingTop" Label="بالا" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.0" Max="10.0" Step="0.1" Format="N1" dir="ltr" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="_settings.PaddingRight" Label="راست" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.0" Max="10.0" Step="0.1" Format="N1" dir="ltr" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="_settings.PaddingBottom" Label="پایین" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.0" Max="10.0" Step="0.1" Format="N1" dir="ltr" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="_settings.PaddingLeft" Label="چپ" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.0" Max="10.0" Step="0.1" Format="N1" dir="ltr" />
                            </MudItem>
                        </MudGrid>
                    </div>

                </MudStack>
            </div>
        }
        else
        {
            <!-- تنظیمات اختصاصی آیتم انتخابی -->
            <div class="panel-header bg-secondary-light">
                <MudIcon Icon="@_selectedItem.GetIcon()" Color="Color.Secondary" Class="me-2" />
                <div class="flex-grow-1 text-start">
                    <MudText Typo="Typo.h6" Class="panel-title text-secondary-dark">ویژگی‌های @_selectedItem.GetLabel()</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => SelectItem(null)" Title="بستن" />
            </div>

            <div class="panel-body">
                <MudStack Spacing="4">
                    
                    <!-- انتخاب موقعیت (شبکه دو در دو) -->
                    <div class="inspector-section">
                        <MudText Typo="Typo.subtitle2" Class="section-title">موقعیت قرارگیری بر روی برچسب</MudText>
                        
                        <div class="quadrant-selector-grid mt-2">
                            <button type="button" class="quadrant-btn @(_selectedItem.Position == BarcodePosition.TopLeft ? "is-active" : "")" 
                                    @onclick="() => ChangeItemPosition(_selectedItem, BarcodePosition.TopLeft)">
                                <div class="quadrant-badge">1</div>
                                <span class="quadrant-lbl">چپ - بالا</span>
                            </button>

                            <button type="button" class="quadrant-btn @(_selectedItem.Position == BarcodePosition.TopRight ? "is-active" : "")" 
                                    @onclick="() => ChangeItemPosition(_selectedItem, BarcodePosition.TopRight)">
                                <div class="quadrant-badge">2</div>
                                <span class="quadrant-lbl">راست - بالا</span>
                            </button>

                            <button type="button" class="quadrant-btn @(_selectedItem.Position == BarcodePosition.BottomLeft ? "is-active" : "")" 
                                    @onclick="() => ChangeItemPosition(_selectedItem, BarcodePosition.BottomLeft)">
                                <div class="quadrant-badge">3</div>
                                <span class="quadrant-lbl">چپ - پایین</span>
                            </button>

                            <button type="button" class="quadrant-btn @(_selectedItem.Position == BarcodePosition.BottomRight ? "is-active" : "")" 
                                    @onclick="() => ChangeItemPosition(_selectedItem, BarcodePosition.BottomRight)">
                                <div class="quadrant-badge">4</div>
                                <span class="quadrant-lbl">راست - پایین</span>
                            </button>
                        </div>
                    </div>

                    <MudDivider />

                    <!-- ویژگی‌های فونت و چیدمان -->
                    <div class="inspector-section">
                        <MudText Typo="Typo.subtitle2" Class="section-title">فونت و چیدمان فیزیکی</MudText>
                        
                        @if (_selectedItem.ItemType != BarcodePrintableItem.Barcode)
                        {
                            <div class="mt-3">
                                <div class="d-flex justify-between align-center mb-1">
                                    <span class="input-label">اندازه قلم متن</span>
                                    <span class="badge-pt">@_selectedItem.FontSize pt</span>
                                </div>
                                <MudSlider @bind-Value="_selectedItem.FontSize" Min="4.0" Max="24.0" Step="0.5" Color="Color.Secondary" Class="py-0" />
                            </div>
                        }

                        <div class="mt-3">
                            <div class="d-flex justify-between align-center mb-1">
                                <span class="input-label">فاصله از خط بعدی</span>
                                <span class="badge-mm">@_selectedItem.ItemSpacing mm</span>
                            </div>
                            <MudSlider @bind-Value="_selectedItem.ItemSpacing" Min="0.0" Max="10.0" Step="0.1" Color="Color.Secondary" Class="py-0" />
                        </div>
                        
                        <div class="mt-3 d-flex align-center justify-between">
                            <span class="input-label">نمایش در چاپ برچسب</span>
                            <MudSwitch @bind-Value="_selectedItem.IsVisible" Color="Color.Secondary" Class="ma-0" />
                        </div>
                    </div>

                    @if (_selectedItem.ItemType == BarcodePrintableItem.Barcode)
                    {
                        <MudDivider />

                        <!-- پارامترهای اختصاصی بارکد فیزیکی -->
                        <div class="inspector-section">
                            <MudText Typo="Typo.subtitle2" Class="section-title">تنظیمات ابعاد فیزیکی بارکد</MudText>

                            <div class="mt-3">
                                <div class="d-flex justify-between align-center mb-1">
                                    <span class="input-label">عرض فیزیکی بارکد</span>
                                    <span class="badge-mm">@_selectedItem.BarcodeWidth mm</span>
                                </div>
                                <MudSlider @bind-Value="_selectedItem.BarcodeWidth" Min="10.0" Max="50.0" Step="0.5" Color="Color.Secondary" Class="py-0" />
                            </div>

                            <div class="mt-3">
                                <div class="d-flex justify-between align-center mb-1">
                                    <span class="input-label">ارتفاع فیزیکی بارکد</span>
                                    <span class="badge-mm">@_selectedItem.BarcodeHeight mm</span>
                                </div>
                                <MudSlider @bind-Value="_selectedItem.BarcodeHeight" Min="3.0" Max="20.0" Step="0.5" Color="Color.Secondary" Class="py-0" />
                            </div>

                            <div class="mt-3">
                                <div class="d-flex justify-between align-center mb-1">
                                    <span class="input-label">حاشیه بیرونی بارکد</span>
                                    <span class="badge-mm">@_selectedItem.BarcodeMargin mm</span>
                                </div>
                                <MudSlider @bind-Value="_selectedItem.BarcodeMargin" Min="0.0" Max="5.0" Step="0.1" Color="Color.Secondary" Class="py-0" />
                            </div>

                            <div class="mt-3">
                                <div class="d-flex justify-between align-center mb-1">
                                    <span class="input-label">ضریب ضخامت خطوط بارکد</span>
                                    <span class="badge-pt">@_selectedItem.BarWidthMultiplier px</span>
                                </div>
                                <MudSlider @bind-Value="_selectedItem.BarWidthMultiplier" Min="1" Max="4" Step="1" Color="Color.Secondary" Class="py-0" />
                            </div>

                            <div class="mt-3 d-flex align-center justify-between">
                                <span class="input-label">نمایش عدد بارکد در زیر آن</span>
                                <MudSwitch @bind-Value="_selectedItem.BarcodeDisplayValue" Color="Color.Secondary" Class="ma-0" />
                            </div>

                            @if (_selectedItem.BarcodeDisplayValue)
                            {
                                <div class="mt-3">
                                    <div class="d-flex justify-between align-center mb-1">
                                        <span class="input-label">اندازه قلم عدد بارکد</span>
                                        <span class="badge-pt">@_selectedItem.BarcodeFontSize pt</span>
                                    </div>
                                    <MudSlider @bind-Value="_selectedItem.BarcodeFontSize" Min="4.0" Max="14.0" Step="0.5" Color="Color.Secondary" Class="py-0" />
                                </div>
                            }
                        </div>
                    }

                    <!-- ترتیب و دکمه حذف -->
                    <MudDivider />
                    
                    @{
                        var positionItems = _settings.GetItemsForPosition(_selectedItem.Position);
                        var isFirst = positionItems.FirstOrDefault() == _selectedItem;
                        var isLast = positionItems.LastOrDefault() == _selectedItem;
                        var hasReorder = positionItems.Count > 1;
                    }
                    
                    @if (hasReorder)
                    {
                        <div class="inspector-section">
                            <MudText Typo="Typo.subtitle2" Class="section-title">چیدمان عمودی آیتم‌ها</MudText>
                            <div class="d-flex gap-2 mt-2">
                                <MudButton Variant="Variant.Outlined" 
                                           StartIcon="@Icons.Material.Filled.ArrowUpward" 
                                           Color="Color.Secondary" 
                                           FullWidth="true" 
                                           OnClick="() => MoveItemOrder(_selectedItem, true)" 
                                           Disabled="isFirst"
                                           Size="Size.Small">
                                    انتقال به بالا
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" 
                                           StartIcon="@Icons.Material.Filled.ArrowDownward" 
                                           Color="Color.Secondary" 
                                           FullWidth="true" 
                                           OnClick="() => MoveItemOrder(_selectedItem, false)" 
                                           Disabled="isLast"
                                           Size="Size.Small">
                                    انتقال به پایین
                                </MudButton>
                            </div>
                        </div>
                        <MudDivider />
                    }

                    <div class="inspector-section">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   FullWidth="true"
                                   OnClick="() => ToggleItemActive(_selectedItem.ItemType)"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   Class="rounded-lg py-2">
                            غیرفعال کردن و حذف از برچسب
                        </MudButton>
                    </div>

                </MudStack>
            </div>
        }
    </div>

        </div> <!-- designer-main-body -->

        <!-- فوتر دکمه‌های عملیاتی -->
        <div class="designer-footer border-solid border-t mud-border-default">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveSettings"
                       StartIcon="@Icons.Material.Filled.Save"
                       Disabled="_isLoading"
                       Class="rounded-lg px-6 py-2.5 font-bold shadow-md footer-action-btn">
                <span class="d-none d-sm-inline">ذخیره قالب بارکد</span>
                <span class="d-inline d-sm-none">ذخیره</span>
            </MudButton>
            
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Info"
                       OnClick="PrintTestBarcode"
                       StartIcon="@Icons.Material.Filled.Print"
                       Class="rounded-lg px-6 py-2 font-bold border-2 footer-action-btn">
                <span class="d-none d-sm-inline">چاپ نمونه تستی</span>
                <span class="d-inline d-sm-none">چاپ تست</span>
            </MudButton>
        </div>

    </div>
</MudCard>

@code {
    private RenderFragment RenderTagItem(BarcodePositionItemVm item)
    {
        return __builder =>
        {
            <div class="visual-element-box @(item.IsVisible ? "" : "is-hidden")">
                
                @if (item.ItemType == BarcodePrintableItem.Barcode)
                {
                    <div class="barcode-preview-block" style="margin: @($"{item.BarcodeMargin}mm") 0;">
                        <!-- خطوط شبیه‌سازی بارکد به صورت SVG با Crisp Edge واقعی -->
                        <div class="barcode-lines" style="width: @($"{item.BarcodeWidth}mm"); height: @($"{item.BarcodeHeight}mm");"></div>
                        @if (item.BarcodeDisplayValue)
                        {
                            <div class="barcode-text" style="font-size: @($"{item.BarcodeFontSize}pt");">10206610</div>
                        }
                    </div>
                }
                else if (item.ItemType == BarcodePrintableItem.ProductName)
                {
                    <div class="text-preview-block font-bold rtl" style="font-size: @($"{item.FontSize}pt"); text-align: center; width: 100%;">
                        گوشواره طلا
                    </div>
                }
                else if (item.ItemType == BarcodePrintableItem.Weight)
                {
                    <div class="text-preview-block ltr" style="font-size: @($"{item.FontSize}pt");">
                        W: 3.250G
                    </div>
                }
                else if (item.ItemType == BarcodePrintableItem.Wage)
                {
                    <div class="text-preview-block ltr" style="font-size: @($"{item.FontSize}pt");">
                        F: 15% + 150T
                    </div>
                }
                
                <!-- لیبل کوچک نام آیتم در صورت عدم هاور یا هاور شدن -->
                <div class="hover-label">@item.GetLabel()</div>
            </div>
        };
    }
}

