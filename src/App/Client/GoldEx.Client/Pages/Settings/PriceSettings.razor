@inherits GoldExComponentBase

@attribute [Route(ClientRoutes.Settings.PriceSettings)]
@attribute [Authorize(Roles = $"{BuiltinRoles.Administrators}, {BuiltinRoles.Owners}")]

<PageTitle>مدیریت نمادها</PageTitle>

<MudText Typo="Typo.h6" GutterBottom="true">مدیریت نمادها</MudText>
<MudDivider Class="my-4" />

@if (!_priceSettings.Any())
{
    <div class="align-center d-flex flex-column gap-3 justify-content-center">
        <MudProgressLinear Color="Color.Info" Indeterminate="true" />
        <div>در حال بارگیری</div>
    </div>
}
else
{
    <MudGrid Spacing="4">
        <MudItem xs="12" lg="6">
            <MudPaper Elevation="24">
                <MudTreeView T="object" SelectionMode="SelectionMode.MultiSelection" Hover="true">
                    @foreach (var response in _priceSettings.GroupBy(r => r.MarketType))
                    {
                        <MudTreeViewItem T="object" Value="response.Key" Text="@response.Key.GetDisplayName()">
                            @foreach (var price in response.SelectMany(r => r.Prices ?? []))
                            {
                                <MudTreeViewItem T="object"
                                                 Value="price"
                                                 Selected="price.IsActive"
                                                 SelectedChanged="context => OnPriceItemSelectionChanged(price.Id, context)">
                                    <BodyContent>
                                        <div class="d-flex align-items-center justify-space-between w-100">
                                            <MudText>@price.Title</MudText>
                                            <MudSpacer />
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                           Color="Color.Info"
                                                           Size="Size.Small"
                                                           OnClick="@(() => OnEditPrice(price))" />
                                            <MudIconButton Icon="@(price.IsPinned? Icons.Material.Filled.PushPin : Icons.Material.Outlined.PushPin)"
                                                           Color="@(price.IsPinned ? Color.Primary : Color.Default)"
                                                           Size="Size.Small"
                                                           OnClick="@(() => OnPinToggleAsync(price.Id, price.IsPinned))" />
                                        </div>
                                    </BodyContent>
                                </MudTreeViewItem>
                            }
                        </MudTreeViewItem>
                    }
                </MudTreeView>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" lg="6">
            <MudPaper Elevation="24" Class="mt-4 p-2">
                <MudText Typo="Typo.h6" Class="text-center">راهنما</MudText>
                <MudDivider Class="mb-2" />

                <div class="d-flex flex-column gap-2">
                    <div class="d-flex gap-2 justify-start">
                        <MudIcon Icon="@Icons.Material.Filled.CheckBox" Color="Color.Primary" />
                        <MudText Typo="Typo.body2" Class="mb-4">
                            نرخ نماد های فعال در صفحه اصلی نمایش داده خواهد شد
                        </MudText>
                    </div>
                    <div class="d-flex gap-2 justify-start">
                        <MudIcon Icon="@Icons.Material.Filled.PushPin" Color="Color.Primary" />
                        <MudText Typo="Typo.body2" Class="mb-4">
                            نرخ نماد های پین شده در صفحه داشبورد نمایش داده خواهد شد
                        </MudText>
                    </div>
                    <div class="d-flex gap-2 justify-start">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Info" />
                        <MudText Typo="Typo.body2" Class="mb-4">
                            برای تغییر ارائه دهنده قیمت هر نماد روی ویرایش آن کلیک کنید
                        </MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}