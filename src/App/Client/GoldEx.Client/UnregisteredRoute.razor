@inject NavigationManager NavigationManager

@using NavigationContext = Microsoft.AspNetCore.Components.Routing.NavigationContext

<Router AppAssembly="typeof(Program).Assembly" AdditionalAssemblies="[typeof(BaseLayout).Assembly]" OnNavigateAsync="OnNavigateAsync">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code{

    public Task OnNavigateAsync(NavigationContext arg)
    {
        if (!arg.Path.Contains(ClientRoutes.RegisterProduct.Index.Replace("/", "")))
            NavigationManager.NavigateTo(ClientRoutes.RegisterProduct.Index);

        return Task.CompletedTask;
    }
}