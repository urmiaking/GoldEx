@using GoldEx.Shared.DTOs.Stores
@using GoldEx.Shared.Services.Abstractions
@using GoldEx.Client.Components.Components
@using MudBlazor
@inherits GoldExComponentBase

<MudDialog Class="store-dialog-custom">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Store" Color="Color.Primary" />
            <MudText Typo="Typo.h6">انتخاب فروشگاه فعال</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <style>
            .store-dialog-custom {
                border-radius: 20px !important;
            }
            .store-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
                gap: 20px;
                padding: 10px 0;
            }
            .store-card {
                position: relative;
                height: 140px;
                border-radius: 16px;
                overflow: hidden;
                cursor: pointer;
                transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                border: 1px solid rgba(var(--mud-palette-divider-rgb), 0.15);
                box-shadow: var(--mud-elevation-4);
                isolation: isolate;
                -webkit-mask-image: -webkit-radial-gradient(white, black);
                background-color: var(--mud-palette-surface);
            }
            .store-card:hover {
                transform: translateY(-6px) scale(1.02);
                box-shadow: var(--mud-elevation-8);
                border-color: var(--mud-palette-primary);
            }
            .store-card-bg {
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                border-radius: inherit;
                background-size: cover;
                background-position: center;
                opacity: 0.35;
                transition: opacity 0.4s ease, transform 0.4s ease;
            }
            .store-card.active-store .store-card-bg {
                opacity: 1.0;
            }
            .store-card:hover .store-card-bg {
                opacity: 1.0;
                transform: scale(1.05);
            }
            .store-card-glass {
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                border-radius: inherit;
                background: rgba(0, 0, 0, 0.08);
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 12px;
                color: var(--mud-palette-text-primary);
            }
            .store-card.active-store {
                border: 2px solid var(--mud-palette-primary);
                box-shadow: 0 0 14px rgba(var(--mud-palette-primary-rgb), 0.35);
            }
            .store-card.active-store .store-card-glass {
                background: rgba(0, 0, 0, 0.04);
            }
            .store-card-text-container {
                background: rgba(var(--mud-palette-surface-rgb), 0.35);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                padding: 6px 10px;
                border-radius: 10px;
                border: 1px solid rgba(255, 255, 255, 0.12);
                width: 100%;
                transition: all 0.3s ease;
            }
            .store-card:hover .store-card-text-container {
                background: rgba(var(--mud-palette-surface-rgb), 0.65);
                border-color: rgba(var(--mud-palette-primary-rgb), 0.3);
            }
            .store-card.active-store .store-card-text-container {
                background: rgba(var(--mud-palette-surface-rgb), 0.75);
                border: 1.5px solid var(--mud-palette-primary);
                box-shadow: 0 0 8px rgba(var(--mud-palette-primary-rgb), 0.15);
            }
            .store-logo {
                width: 48px;
                height: 48px;
                border-radius: 12px;
                background: rgba(var(--mud-palette-action-default-rgb), 0.1);
                display: flex;
                align-items: center;
                justify-content: center;
                border: 1px solid rgba(var(--mud-palette-action-default-rgb), 0.2);
                font-size: 1.5rem;
                overflow: hidden;
                color: var(--mud-palette-primary);
            }
            .store-logo img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }
            .active-badge {
                background: var(--mud-palette-success);
                color: var(--mud-palette-success-text);
                font-size: 0.7rem;
                padding: 2px 10px;
                border-radius: 20px;
                box-shadow: 0 4px 10px rgba(var(--mud-palette-success-rgb), 0.3);
            }
            .default-badge {
                background: rgba(var(--mud-palette-action-default-rgb), 0.15);
                color: var(--mud-palette-text-primary);
                font-size: 0.7rem;
                padding: 2px 8px;
                border-radius: 20px;
            }
        </style>
 
        @if (IsBusy && _stores.Count == 0)
        {
            <div class="d-flex justify-center my-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (_stores.Count == 0)
        {
            <div class="text-center my-8">
                <MudIcon Icon="@Icons.Material.Filled.Storefront" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">هیچ فروشگاهی یافت نشد.</MudText>
            </div>
        }
        else
        {
            <div class="store-grid">
                @foreach (var store in _stores)
                {
                    var activeClass = store.IsCurrent ? "active-store" : "";
                    var backgroundUrl = string.IsNullOrWhiteSpace(store.BackgroundImageUrl) 
                        ? "/assets/images/store-default-bg.jpg" 
                        : store.BackgroundImageUrl;
 
                    <div class="store-card @activeClass" @onclick="() => SelectStoreAsync(store)">
                        <div class="store-card-bg" style="background-image: url('@backgroundUrl');"></div>
                        <div class="store-card-glass">
                            <div class="d-flex justify-space-between align-start">
                                <div class="store-logo">
                                    @if (!string.IsNullOrWhiteSpace(store.LogoUrl))
                                    {
                                        <img src="@store.LogoUrl" alt="@store.Name" />
                                    }
                                    else
                                    {
                                        <span>@store.Name.Substring(0, 1)</span>
                                    }
                                </div>
                                @if (store.IsCurrent)
                                {
                                    <span class="active-badge">فعال</span>
                                }
                                else if (store.IsDefault)
                                {
                                    <span class="default-badge">پیش‌فرض</span>
                                }
                            </div>
                            <div class="align-center d-flex justify-content-between store-card-text-container">
                                 <MudText Typo="Typo.body1">@store.Name</MudText>
                                 <MudText Typo="Typo.body2" Color="Color.Primary" Class="d-block mt-1">@store.Slug</MudText>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private List<UserStoreDto> _stores = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadStoresAsync();
    }

    private async Task LoadStoresAsync()
    {
        var result = await SendRequestAsync<IStoreService, List<UserStoreDto>>(
            (service, token) => service.GetUserStoresAsync(token));
        
        if (result != null)
        {
            _stores = result;
        }
    }

    private async Task SelectStoreAsync(UserStoreDto store)
    {
        if (store.IsCurrent)
        {
            MudDialog.Close();
            return;
        }

        await SendRequestAsync<IStoreService>(
            (service, token) => service.SwitchStoreAsync(store.Id, token));

        AddSuccessToast($"فروشگاه فعال به {store.Name} تغییر یافت.");
        MudDialog.Close();
        
        // Force reload the client to apply new context
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }
}
