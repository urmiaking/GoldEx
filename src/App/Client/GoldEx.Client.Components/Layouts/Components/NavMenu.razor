@using GoldEx.Shared.Routings
@using Microsoft.JSInterop

@inherits GoldExComponentBase

<MudNavMenu Rounded="true" Margin="Margin.Dense" Color="Color.Primary">
    <MudNavLink Href="@ClientRoutes.Home.Index" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
        صفحه اصلی
    </MudNavLink>
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="@ClientRoutes.Dashboard.Index" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                داشبورد
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
    <MudNavLink Href="@ClientRoutes.Calculator.Index" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Outlined.Calculate">
        محاسبه گر
    </MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="@ClientRoutes.Invoices.Index" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.LibraryBooks">
                فاکتور ها
            </MudNavLink>
            <MudNavLink Href="@ClientRoutes.InventoryStocks.Index" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Warehouse">
                مدیریت انبار
            </MudNavLink>
            <MudNavLink Href="@ClientRoutes.Customers.Index" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.PeopleAlt">
                مشتریان
            </MudNavLink>
            <MudNavLink Href="@ClientRoutes.Reporting.Index" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.BarChart">
                گزارش ها
            </MudNavLink>
            <MudNavLink Href="@ClientRoutes.PaymentVouchers.Index" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Payment">
                اسناد پرداخت
            </MudNavLink>
            <MudNavLink Href="@ClientRoutes.Accounts.Manage.Index" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Person">
                مدیریت حساب
            </MudNavLink>
            <MudNavLink Href="@ClientRoutes.Settings.Index" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Settings">
                تنظیمات
            </MudNavLink>
            <MudNavLink Href="@ClientRoutes.Blogs.Index" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Help">
                راهنما
            </MudNavLink>

            @* فقط اگر مرورگر می‌گه «قابل نصب است» دکمه را نشان بده *@
            @if (_canInstall)
            {
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudNavLink Icon="@Icons.Material.Filled.InstallDesktop"
                                OnClick="@InstallPwa"
                                Match="NavLinkMatch.All">
                        نصب اپلیکیشن
                    </MudNavLink>
                </MudHidden>
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <MudNavLink Icon="@Icons.Material.Filled.InstallMobile"
                                OnClick="@InstallPwa"
                                Match="NavLinkMatch.All">
                        نصب اپلیکیشن
                    </MudNavLink>
                </MudHidden>
            }

            <MudNavLink Href="@ApiUrls.Account.Logout(_currentUrl)" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Logout">
                خروج
            </MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    private string? _currentUrl;
    private bool _canInstall;

    [Parameter] public EventCallback<bool> OnNavigate { get; set; }
    [Inject] private IJSRuntime JsRuntime { get; set; } = default!;

    protected override void OnInitialized()
    {
        _currentUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // فقط از JS می‌پرسیم "آیا الان می‌تونی نصب کنی؟"
                _canInstall = await JsRuntime.InvokeAsync<bool>("getPwaState");
                if (_canInstall)
                {
                    StateHasChanged();
                }
            }
            catch
            {
                // اگر JS خراب شد، دکمه پنهان می‌ماند
                _canInstall = false;
            }
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUrl = Navigation.ToBaseRelativePath(e.Location);
        await OnNavigate.InvokeAsync(false); // Close the drawer
        StateHasChanged();
    }

    public override ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        return base.DisposeAsync();
    }

    private async Task InstallPwa()
    {
        try
        {
            var installed = await JsRuntime.InvokeAsync<bool>("installPwa");
            if (installed)
            {
                _canInstall = false;   // بعد از نصب، دکمه را پنهان کن
                StateHasChanged();
            }
        }
        catch
        {
            AddErrorToast("خطایی در نصب رخ داد");
        }
    }
}