@using GoldEx.Sdk.Common.Extensions
@using GoldEx.Shared.Enums
@using GoldEx.Shared.Routings

@inherits GoldExComponentBase 

@if (_licenseInfo is not null)
{
    @* UNREGISTERED *@
    if (_licenseInfo.Plan == LicensePlan.Unregistered)
    {
        <MudButton Class="mt-2"
                   Color="Color.Success"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Key"
                   Size="Size.Small"
                   Href="@ClientRoutes.RegisterProduct.Index">
            فعال‌سازی نرم افزار
        </MudButton>
    }
    else
    {
        <MudText Class="mt-2"
                 Typo="Typo.body2"
                 Color="GetLicenseColor(_licenseInfo)">
            @_licenseInfo.Plan.GetDisplayName()
            @(_licenseInfo.IsExpired ? " (منقضی شده)" : "")
        </MudText>

        @* PROGRESS (only when still valid) *@
        @if (RemainingDays > 0)
        {
            <MudProgressLinear Class="mt-2"
                               Value="@GetLicenseProgress(_licenseInfo)"
                               Color="GetLicenseColor(_licenseInfo)"
                               Striped="RemainingDays <= 7" /> 

            <MudText Typo="Typo.caption" Align="Align.Center">
                @RemainingDays روز تا پایان اشتراک
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.caption" Align="Align.Center">
                تاریخ پایان اشتراک: @_licenseInfo.ExpireDate.ToString("yyyy/MM/dd")
            </MudText>
        }

        @* ACTIONS *@
        @if (_licenseInfo.Plan == LicensePlan.Trial)
        {
            <MudButton Class="mt-2"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Stars"
                       Href="@ClientRoutes.RegisterProduct.Upgrade"
                       Size="Size.Small">
                ارتقا به نسخه کامل
            </MudButton>
        }
        else if (_licenseInfo.Plan == LicensePlan.Regular && RemainingDays <= 7)
        {
            <MudButton Class="mt-2"
                       Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       Href="@ClientRoutes.RegisterProduct.Extend"
                       Size="Size.Small">
                تمدید اشتراک نرم افزار
            </MudButton>
        }
    }
}