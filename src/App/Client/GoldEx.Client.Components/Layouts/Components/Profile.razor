@using GoldEx.Sdk.Common.Extensions
@using GoldEx.Shared.Enums
@using GoldEx.Shared.Routings
@using Humanizer
@inherits GoldEx.Client.Components.Components.GoldExComponentBase

<AuthorizeView>
    <Authorized>
        <MudIconButton Color="Color.Inherit" Edge="Edge.End" OnClick="ToggleProfile" Icon="@Icons.Material.Filled.Person">
        </MudIconButton>

        <MudPopover Open="@_isProfileOpen" Fixed="false" TransformOrigin="Origin.TopLeft" AnchorOrigin="Origin.BottomLeft" Class="px-4 pt-4" Elevation="24">
            <MudIconButton OnClick="@ToggleProfile" Class="p-0 m-0" Color="Color.Error" Icon="@Icons.Material.Filled.Close"></MudIconButton>

            <div class="d-flex flex-column align-center">
                <div class="d-flex flex-column align-center">
                    <MudAvatar Size="Size.Large" Color="Color.Secondary">
                        <MudImage Src="@ApiUrls.Icons.Get(IconType.App, Guid.Empty)" />
                    </MudAvatar>
                    <MudChip T="string" Class="mt-n2" Color="@_color" Size="Size.Small">@_status</MudChip>
                </div>

                <MudText Typo="Typo.h6" Class="mt-2">@_username</MudText>
                <MudText Typo="Typo.body2">
                    @context.User.Identity?.Name
                </MudText>
                <LicenseStatus />
            </div>

            <MudDivider Class="my-4" />


            <!-- Color Palette Selector -->
            <div class="d-flex flex-column align-center">
                <MudText Typo="Typo.subtitle2" Class="mb-2">انتخاب تم</MudText>
                <div class="d-flex gap-2 flex-wrap justify-center">
                    <div class="palette-collection">
                        @{
                            var predefinedColors = new Dictionary<string, string>
                                                {
                                                { "Gold", "#DAA520" },
                                                { "Blue", "#1976D2" },
                                                { "Purple", "#7B1FA2" },
                                                { "Green", "#388E3C" },
                                                { "Orange", "#F57C00" },
                                                { "Red", "#D32F2F" }
                                                };
                        }

                        @foreach (var color in predefinedColors)
                        {
                            <div class="palette-dot @(ThemeService?.CurrentPalette == color.Key ? "selected" : "")"
                                 style="background-color: @color.Value;"
                                 @onclick="@(() => OnPaletteSelected(color.Key))">
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="d-flex align-center justify-center">
                <MudText Typo="Typo.subtitle2">حالت تاریک</MudText>
                <MudSwitch Value="@_isDarkMode"
                           ValueChanged="@OnDarkModeToggleChanged"
                           T="bool"
                           ThumbIcon="@(_isDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)"
                           ThumbIconColor="Color.Error"
                           Color="Color.Inherit"
                           Size="Size.Large" />
            </div>

            <MudDivider Class="my-4" />


            <div class="d-flex flex-column align-center">
                <MudButtonGroup Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="mb-4">
                    <MudTooltip Text="مدیریت حساب" Placement="Placement.Right" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.ManageAccounts" Href="@ClientRoutes.UserAccounts.Index"></MudIconButton>
                    </MudTooltip>

                    <MudTooltip Text="عملکرد برنامه" Placement="Placement.Bottom" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.MonitorHeart" OnClick="() => _healthMonitorOpen = !_healthMonitorOpen"></MudIconButton>
                        <MudPopover Open="_healthMonitorOpen" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                            <HealthMonitor />
                        </MudPopover>
                    </MudTooltip>

                    <MudTooltip Text="گزارش خطاهای برنامه" Placement="Placement.Bottom" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.ErrorOutline" Href="@ClientRoutes.Logs.Base"></MudIconButton>
                    </MudTooltip>

                    <MudTooltip Text="خروج" Placement="Placement.Right" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.ExitToApp" Href="@ApiUrls.Account.Logout(_currentUrl)"></MudIconButton>
                    </MudTooltip>
                </MudButtonGroup>
            </div>

        </MudPopover>
    </Authorized>
    <NotAuthorized>
        <MudIconButton Color="Color.Inherit" Edge="Edge.End" Icon="@Icons.Material.Filled.Key" Href="@ClientRoutes.Accounts.Login"></MudIconButton>
    </NotAuthorized>
</AuthorizeView>