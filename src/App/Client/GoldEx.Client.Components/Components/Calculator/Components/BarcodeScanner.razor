<MudPaper Class="pa-4 my-2" Elevation="4" Outlined="true">
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="d-flex justify-center align-center flex-column gap-2" style="height: 300px;">
            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
            <MudText Color="Color.Error">@_errorMessage</MudText>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RestartProcess">تلاش دوباره</MudButton>
        </div>
    }
    else if (!_isInitialized)
    {
        @* SHOW SPINNER UNTIL WE HAVE SELECTED A CAMERA *@
        <div class="d-flex justify-center align-center flex-column gap-2" style="height: 300px; background-color: black; border-radius: 4px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.caption" Class="white-text">درحال راه اندازی دوربین...</MudText>
        </div>
    }
    else
    {
        <div class="scanner-wrapper">

            <BarcodeReader @ref="_reader"
                           ScanResult="HandleBarcode"
                           OnError="HandleError"
                           UseBuiltinDiv="true"
                           DeviceID="@_selectedDeviceId"
                           Options="_options" />

            @if (_cameraDevices.Count > 1)
            {
                <div style="position: absolute; top: 10px; left: 10px; z-index: 10000;">
                    <MudMenu Icon="@Icons.Material.Filled.Cameraswitch"
                             Color="Color.Surface"
                             Variant="Variant.Filled"
                             Size="Size.Small"
                             AnchorOrigin="Origin.BottomLeft"
                             TransformOrigin="Origin.TopLeft">
                        @foreach (var dev in _cameraDevices)
                        {
                            <MudMenuItem OnClick="() => ChangeCamera(dev.DeviceId)">
                                <MudText Typo="Typo.body2">@CleanLabel(dev.Label)</MudText>
                            </MudMenuItem>
                        }
                    </MudMenu>
                </div>
            }

            <div style="position: absolute; bottom: 10px; width: 100%; text-align: center; z-index: 9999;">
                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="CloseScanner">بستن دوربین</MudButton>
            </div>
        </div>
    }
</MudPaper>

@code {
    [Parameter] public EventCallback<string> OnResult { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Inject] private IJSRuntime JsRuntime { get; set; } = null!;

    private BarcodeReader? _reader;
    private string? _errorMessage;
    private string? _lastResult;
    private bool _isInitialized = false;

    public class CameraDevice { public string DeviceId { get; set; } = ""; public string Label { get; set; } = ""; }
    private List<CameraDevice> _cameraDevices = new();

    private string? _selectedDeviceId;

    private readonly ZXingOptions _options = new()
    {
        DecodeAllFormats = false,
        formats = [BarcodeFormat.CODE_128],
        TRY_HARDER = true
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Step 1: Initialize immediately (don't wait 2 seconds, just do it)
            await InitializeCameraAsync();
        }
    }

    private async Task InitializeCameraAsync()
    {
        try
        {
            _errorMessage = null;

            // Step 2: Ask JS for devices.
            // The JS logic now opens a stream, gets permission, AND CLOSES IT IMMEDIATELY.
            var devices = await JsRuntime.InvokeAsync<List<CameraDevice>>("GoldEx.getVideoDevices");

            if (devices != null && devices.Any())
            {
                _cameraDevices = devices
                    .Where(x => !string.IsNullOrEmpty(x.Label))
                    .GroupBy(x => x.DeviceId)
                    .Select(g => g.First())
                    .ToList();

                // Step 3: Smart Selection
                // Try to find a "back" camera. If not, take the last one (usually back on Android).
                var backCamera = _cameraDevices.FirstOrDefault(x => x.Label.ToLower().Contains("back"))
                                 ?? _cameraDevices.LastOrDefault();

                _selectedDeviceId = backCamera?.DeviceId ?? _cameraDevices.First().DeviceId;
            }

            // Step 4: Now we allow the library to render
            _isInitialized = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _errorMessage = "خطا در دسترسی به لیست دوربین‌ها: " + ex.Message;
            StateHasChanged();
        }
    }

    private async Task ChangeCamera(string deviceId)
    {
        // To switch cameras safely, we hide the reader, change ID, then show it again
        // This forces a hard-reset of the hardware connection
        _isInitialized = false;
        StateHasChanged();

        await Task.Delay(100);
        _selectedDeviceId = deviceId;

        _isInitialized = true;
        StateHasChanged();
    }

    private async Task RestartProcess()
    {
        _isInitialized = false;
        _errorMessage = null;
        StateHasChanged();
        await Task.Delay(500);
        await InitializeCameraAsync();
    }

    private async Task HandleBarcode(string result)
    {
        if (string.IsNullOrWhiteSpace(result)) return;
        if (_lastResult == result) return;
        _lastResult = result;
        await OnResult.InvokeAsync(result);
    }

    private async Task CloseScanner()
    {
        if (_reader != null) await _reader.Stop();
        await OnClose.InvokeAsync();
    }

    private Task HandleError(string message)
    {
        // Don't overwrite error if we are just switching cameras
        if (!_isInitialized) return Task.CompletedTask;

        _errorMessage = message;
        if (_errorMessage.Contains("NotAllowedError") || _errorMessage.Contains("Permission denied"))
            _errorMessage = "دسترسی به دوربین مجاز نیست.";
        else if (_errorMessage.Contains("NotFoundError"))
            _errorMessage = "دوربینی پیدا نشد.";
        else if (_errorMessage.Contains("NotReadableError"))
            _errorMessage = "دوربین درگیر است. لطفا دوباره تلاش کنید.";

        StateHasChanged();
        return Task.CompletedTask;
    }

    private string CleanLabel(string label)
    {
        if (string.IsNullOrEmpty(label)) return "دوربین";
        return label.Length > 25 ? label.Substring(0, 25) + "..." : label;
    }
}

<script>
    window.GoldEx = {
        getVideoDevices: async function () {
            try {
                // 1. Request Permission (Opens a stream)
                // We use 'ideal' constraints to be gentle on hardware
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } });

                // 2. CRITICAL FIX: Stop the stream IMMEDIATELY.
                // If we don't do this, the stream stays open. When ZXing tries to open it
                // a millisecond later, Samsung throws "NotReadableError" (Device Busy).
                stream.getTracks().forEach(track => track.stop());

                // 3. Now that permission is granted and hardware is free, list the devices
                const devices = await navigator.mediaDevices.enumerateDevices();

                return devices
                    .filter(device => device.kind === 'videoinput')
                    .map(device => ({ deviceId: device.deviceId, label: device.label }));
            } catch (err) {
                console.error("Camera Init Error:", err);
                // Even if getUserMedia fails (e.g. already permitted but locked), try enumerating
                try {
                     const devices = await navigator.mediaDevices.enumerateDevices();
                     return devices.filter(d => d.kind === 'videoinput').map(d => ({ deviceId: d.deviceId, label: d.label }));
                } catch (e) { return []; }
            }
        }
    };
</script>