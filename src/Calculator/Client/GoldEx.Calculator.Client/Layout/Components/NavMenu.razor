@inherits GoldExComponentBase

<MudNavMenu Rounded="true" Margin="Margin.Dense" Color="Color.Primary">
    <MudNavLink Href="@ClientRoutes.Home.Index" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Calculate" IconColor="Color.Info">
        محاسبه گر طلا
    </MudNavLink>
    <MudNavLink Href="@ClientRoutes.Calculator.Currency" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.CurrencyExchange" IconColor="Color.Error">
        تبدیل ارز
    </MudNavLink>
    <MudNavLink Href="@ClientRoutes.Calculator.Reverse" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.SwapHoriz" IconColor="Color.Success">
        ارز به طلا
    </MudNavLink>
    <MudNavLink Href="@ClientRoutes.About.Index" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Info" IconColor="Color.Tertiary">
        درباره برنامه
    </MudNavLink>
</MudNavMenu>

@code
{
    [Parameter] public EventCallback<bool> OnNavigate { get; set; }
    [Inject] private IJSRuntime JsRuntime { get; set; } = default!;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await OnNavigate.InvokeAsync(false);
        StateHasChanged();
    }

    public override ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        return base.DisposeAsync();
    }
}
