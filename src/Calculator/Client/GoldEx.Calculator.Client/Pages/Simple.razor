@attribute [Route(ClientRoutes.Home.Index)]
@attribute [Route(ClientRoutes.Calculator.Simple)]

@using GoldEx.Calculator.Client.Components
@inherits GoldExComponentBase

<PageTitle>ماشین حساب گلدکس</PageTitle>

<div class="container">
    <div class="row">

        <MudGrid Class="position-relative" Spacing="0">
            
            @if (!_isLoggedIn)
            {
                <!-- Desktop Button -->
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Login"
                               Href="@GoldEx.Shared.Routings.ClientRoutes.Accounts.Login"
                               Class="position-absolute top-50 ml-3">
                        ورود به حساب کاربری
                    </MudButton>
                </MudHidden>
            }

            <MudItem xs="12" Class="text-center">
                <MudText Typo="Typo.h4" Class="mb-2 mt-4">محاسبه قیمت طلا</MudText>
                <MudText Typo="Typo.body1">بر اساس فرمول محاسبه اتحادیه طلا</MudText>
            </MudItem>

            @if (_canInstall)
            {
                <!-- Desktop Button -->
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.InstallDesktop"
                               OnClick="InstallPwa"
                               Class="position-absolute start-0 top-50 ml-3">
                        نصب اپلیکیشن
                    </MudButton>
                </MudHidden>

                <!-- Mobile Button -->
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <MudItem xs="12" Class="d-flex justify-center pt-3">
                        <MudButton Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.InstallMobile"
                                   OnClick="InstallPwa"
                                   Color="Color.Primary">
                            نصب اپلیکیشن
                        </MudButton>
                    </MudItem>
                </MudHidden>
            }
            
            @if (!_isLoggedIn)
            {

                <!-- Mobile Button -->
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <MudItem xs="12" Class="d-flex justify-center pt-3">
                        <MudButton Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.Login"
                                   Href="@GoldEx.Shared.Routings.ClientRoutes.Accounts.Login"
                                   Color="Color.Primary">
                            ورود به حساب کاربری
                        </MudButton>
                    </MudItem>
                </MudHidden>
            }

        </MudGrid>
    </div>

    <SimpleCalculator Class="mt-4" 
                      Elevation="24" 
                      EnableQuickInvoice="true"
                      OnAddToInvoice="HandleAddToInvoiceAsync" />
</div>

@if (_basketCount > 0)
{
    <div class="quick-invoice-fab">
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <QuickInvoiceSpeedDial Count="@_basketCount"
                                   OnOpenList="OpenBasketDialogAsync"
                                   OnFinalize="FinalizeInvoiceAsync" />
        </MudHidden>

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Class="shadow">
                <MudButton StartIcon="@Icons.Material.Filled.ShoppingCartCheckout" OnClick="FinalizeInvoiceAsync">
                    صدور فاکتور (@_basketCount)
                </MudButton>
                <MudTooltip Text="مشاهده اقلام">
                    <MudIconButton Icon="@Icons.Material.Filled.ListAlt" Color="Color.Info" Variant="Variant.Filled" OnClick="OpenBasketDialogAsync" />
                </MudTooltip>
            </MudButtonGroup>
        </MudHidden>
    </div>
}
