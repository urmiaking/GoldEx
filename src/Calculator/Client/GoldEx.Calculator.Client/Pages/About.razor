@attribute [Route(ClientRoutes.About.Index)]

<PageTitle>درباره گلدکس</PageTitle>

<div class="container">
    <div class="row">
        <!-- About Content -->
        <div class="col-12 mt-5">

            <MudPaper Class="pa-6 mb-6" Elevation="14">
                <MudStack Spacing="3">

                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Diamond" Color="Color.Warning" Size="Size.Large" />
                        <MudText Typo="Typo.h6">درباره GoldEx Mini</MudText>
                    </MudStack>

                    <MudText Typo="Typo.body1" Class="text-justify">
                        GoldEx Mini یک ابزار حرفه‌ای برای محاسبه دقیق قیمت طلا، طلای آبشده، طلای کهنه و تبدیل ارز است
                        که تحت برند گلدکس توسعه داده شده است. این برنامه با هدف افزایش سرعت، دقت و اطمینان در محاسبات روزانه صنف طلا و جواهر طراحی شده است.
                    </MudText>

                </MudStack>
            </MudPaper>

            <MudPaper Class="pa-6 mb-6" Elevation="14">
                <MudStack Spacing="4">

                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Calculate" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.h6">امکانات اصلی برنامه</MudText>
                    </MudStack>

                    <MudGrid Spacing="3">

                        <MudItem xs="12" md="6">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Scale" Color="Color.Secondary" />
                                <MudText>محاسبه قیمت طلای آبشده بر اساس نرخ روز و درصد سود</MudText>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Color="Color.Secondary" />
                                <MudText>محاسبه طلای کهنه با کسر اجرت و درصد</MudText>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.CurrencyExchange" Color="Color.Secondary" />
                                <MudText>مبدل ارز با امکان ورود نرخ دلخواه</MudText>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Straighten" Color="Color.Secondary" />
                                <MudText>محاسبه وزن طلا بر اساس مبلغ و نرخ ورودی</MudText>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Color="Color.Secondary" />
                                <MudText>صدور فاکتور سریع: افزودن چند قلم به سبد و چاپ فاکتور در لحظه</MudText>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Secondary" />
                                <MudText>مدیریت سبد فاکتور: مشاهده اقلام و حذف هر قلم قبل از نهایی‌سازی</MudText>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Print" Color="Color.Secondary" />
                                <MudText>چاپ استاندارد فاکتور (A5 افقی) با نمایش نرخ روز، اجرت و جمع کل</MudText>
                            </MudStack>
                        </MudItem>

                    </MudGrid>

                </MudStack>
            </MudPaper>

            <MudPaper Class="pa-6 mb-6" Elevation="14">
                <MudStack Spacing="3">

                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Success" Size="Size.Large" />
                        <MudText Typo="Typo.h6">چرا GoldEx Mini؟</MudText>
                    </MudStack>

                    <MudText>
                        • دقت بالا در محاسبات مالی حساس
                    </MudText>
                    <MudText>
                        • طراحی ساده، سریع و مناسب استفاده روزانه
                    </MudText>
                    <MudText>
                        • کاهش خطای انسانی در معاملات
                    </MudText>
                    <MudText>
                        • توسعه‌یافته با تکنولوژی‌های مدرن
                    </MudText>

                </MudStack>
            </MudPaper>

            <MudPaper Class="pa-6 mb-10" Elevation="14">
                <MudStack Spacing="3">

                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.AutoGraph" Color="Color.Info" Size="Size.Large" />
                        <MudText Typo="Typo.h6">ماموریت ما</MudText>
                    </MudStack>

                    <MudText Typo="Typo.body1" Class="text-justify">
                        هدف ما در گلدکس، ارائه ابزارهای دقیق، قابل اعتماد و حرفه‌ای برای صنف طلا و جواهر است.
                        GoldEx Mini گامی در مسیر دیجیتال‌سازی و استانداردسازی محاسبات مالی این حوزه می‌باشد.
                    </MudText>

                </MudStack>
            </MudPaper>

        </div>
    </div>
</div>