<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">اطلاعات مشتری</MudText>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.CustomerName"
                                  Label="نام مشتری"
                                  Required="true"
                                  RequiredError="نام مشتری الزامی است"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Person"
                                  Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.CustomerPhone"
                                  Label="شماره تماس مشتری"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Phone"
                                  Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" Class="mt-3">
                    @if (_companyInfoHasSavedValue)
                    {
                        <MudExpansionPanels Elevation="0">
                            <MudExpansionPanel Text="اطلاعات فروشگاه" Expanded="false">
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_model.CompanyName"
                                                      Label="نام فروشگاه"
                                                      Required="true"
                                                      RequiredError="نام فروشگاه الزامی است"
                                                      Margin="Margin.Dense"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.Storefront"
                                                      Variant="Variant.Outlined" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="_model.CompanyPhone"
                                                      Label="شماره تماس فروشگاه"
                                                      Required="true"
                                                      RequiredError="شماره تماس فروشگاه الزامی است"
                                                      Margin="Margin.Dense"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.Call"
                                                      Variant="Variant.Outlined" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="_model.CompanyAddress"
                                                      Label="آدرس فروشگاه"
                                                      Required="true"
                                                      RequiredError="آدرس فروشگاه الزامی است"
                                                      Margin="Margin.Dense"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.LocationOn"
                                                      Variant="Variant.Outlined"
                                                      Lines="2" />
                                    </MudItem>
                                    <MudItem xs="12" Class="d-flex align-center gap-4 mt-2">
                                        @if (!string.IsNullOrEmpty(_model.CompanyLogo))
                                        {
                                            <div class="d-flex align-center gap-3 border p-2 rounded" style="border-color: var(--mud-palette-divider);">
                                                <img src="@_model.CompanyLogo" alt="لوگوی فروشگاه" style="max-height: 80px; max-width: 120px; object-fit: contain;" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="ClearLogo" Tooltip="حذف لوگو" />
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-column gap-1">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">لوگوی فروشگاه (تصویر، حداکثر ۵۰۰ کیلوبایت)</MudText>
                                                <InputFile id="logoUploadPanel" OnChange="UploadLogoAsync" accept=".jpg,.jpeg,.png,.webp" style="display:none;" />
                                                <MudButton HtmlTag="label"
                                                           Variant="Variant.Outlined"
                                                           Color="Color.Info"
                                                           StartIcon="@Icons.Material.Filled.CloudUpload"
                                                           for="logoUploadPanel">
                                                    بارگذاری لوگو
                                                </MudButton>
                                            </div>
                                        }
                                    </MudItem>
                                </MudGrid>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle1" Class="mb-2">اطلاعات فروشگاه</MudText>

                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_model.CompanyName"
                                              Label="نام فروشگاه"
                                              Required="true"
                                              RequiredError="نام فروشگاه الزامی است"
                                              Margin="Margin.Dense"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Storefront"
                                              Variant="Variant.Outlined" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_model.CompanyPhone"
                                              Label="شماره تماس فروشگاه"
                                              Required="true"
                                              RequiredError="شماره تماس فروشگاه الزامی است"
                                              Margin="Margin.Dense"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Call"
                                              Variant="Variant.Outlined" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_model.CompanyAddress"
                                              Label="آدرس فروشگاه"
                                              Required="true"
                                              RequiredError="آدرس فروشگاه الزامی است"
                                              Margin="Margin.Dense"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.LocationOn"
                                              Variant="Variant.Outlined"
                                              Lines="2" />
                            </MudItem>
                            <MudItem xs="12" Class="d-flex align-center gap-4 mt-2">
                                @if (!string.IsNullOrEmpty(_model.CompanyLogo))
                                {
                                    <div class="d-flex align-center gap-3 border p-2 rounded" style="border-color: var(--mud-palette-divider);">
                                        <img src="@_model.CompanyLogo" alt="لوگوی فروشگاه" style="max-height: 80px; max-width: 120px; object-fit: contain;" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="ClearLogo" Tooltip="حذف لوگو" />
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex flex-column gap-1">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">لوگوی فروشگاه (تصویر، حداکثر ۵۰۰ کیلوبایت)</MudText>
                                        <InputFile id="logoUploadDirect" OnChange="UploadLogoAsync" accept=".jpg,.jpeg,.png,.webp" style="display:none;" />
                                        <MudButton HtmlTag="label"
                                                   Variant="Variant.Outlined"
                                                   Color="Color.Info"
                                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                                   for="logoUploadDirect">
                                            بارگذاری لوگو
                                        </MudButton>
                                    </div>
                                }
                            </MudItem>
                        </MudGrid>
                    }
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <div class="p-3 d-flex gap-2">
            <MudButton Variant="Variant.Text" OnClick="Cancel">انصراف</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAsync">چاپ فاکتور</MudButton>
        </div>
    </DialogActions>
</MudDialog>